{
  "name": "astro-blog",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "dev": "portless run --name keroway astro dev",
    "start": "portless run --name keroway astro dev",
    "dev:astro": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "biome ci .",
    "format": "biome format --write .",
    "check": "biome check .",
    "lint:alt": "node --experimental-strip-types scripts/lint-alt.ts",
    "suggest-frontmatter": "node --experimental-strip-types scripts/suggest-frontmatter.ts",
    "new-post": "node --experimental-strip-types scripts/new-post.ts"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.177",
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdoc": "1.0.6",
    "@astrojs/react": "^5.0.7",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "^2.5.0",
    "@fontsource/zen-maru-gothic": "^5.2.8",
    "@keystatic/astro": "^5.0.6",
    "@keystatic/core": "^0.5.50",
    "@markdoc/markdoc": "0.5.7",
    "@playwright/test": "^1.60.0",
    "@resvg/resvg-js": "^2.6.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@unocss/astro": "^66.7.2",
    "astro": "^6.4.6",
    "portless": "^0.14.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "satori": "^0.26.0",
    "typescript": "^6.0.0",
    "unocss": "^66.7.2"
  },
  "dependencies": {
    "@astrojs/vercel": "10.0.8"
  }
