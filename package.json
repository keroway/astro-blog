{
  "name": "astro-blog",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "dev": "portless run --name keroway astro dev",
    "start": "portless run --name keroway astro dev",
    "dev:astro": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "biome ci .",
    "format": "biome format --write .",
    "check": "biome check .",
    "lint:alt": "node --experimental-strip-types scripts/lint-alt.ts",
    "suggest-frontmatter": "node --experimental-strip-types scripts/suggest-frontmatter.ts",
    "backfill-descriptions": "node --experimental-strip-types scripts/backfill-descriptions.ts",
    "suggest-alt": "node --experimental-strip-types scripts/suggest-alt.ts",
    "migrate-remote-images": "node --experimental-strip-types scripts/migrate-remote-images.ts",
    "backfill-alt-text": "node --experimental-strip-types scripts/backfill-alt-text.ts",
    "new-post": "node --experimental-strip-types scripts/new-post.ts",
    "test:e2e": "CRON_SECRET=ci-test-secret playwright test",
    "test:lighthouse": "npx --yes @lhci/cli@0.14 autorun",
    "test:links": "lychee --no-progress --include-fragments --root-dir dist/client --fallback-extensions html 'dist/client/**/*.html'",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.201",
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdoc": "2.0.3",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/vercel": "11.0.2",
    "@axe-core/playwright": "^4.12.1",
    "@biomejs/biome": "^2.5.2",
    "@fontsource/zen-maru-gothic": "^5.2.8",
    "@markdoc/markdoc": "0.5.7",
    "@playwright/test": "^1.61.1",
    "@resvg/resvg-js": "^2.6.2",
    "@sveltia/cms": "^0.168.0",
    "@unocss/astro": "^66.7.3",
    "astro": "^7.0.6",
    "pagefind": "^1.5.2",
    "portless": "^0.15.1",
    "satori": "^0.26.0",
    "sharp": "^0.35.2",
    "sirv": "^3.0.0",
    "typescript": "^6.0.0",
    "unocss": "^66.7.4",
    "vitest": "^4.1.9",
    "yaml": "^2.9.0"
  }
}
