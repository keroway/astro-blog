---
import SiteLayout from '../layouts/SiteLayout.astro';
import { SITE_TITLE, SITE_DESCRIPTION, SITE_VOLUME } from '../consts';
import Monogram from '../components/Monogram.astro';
import HeroBackdrop from '../components/HeroBackdrop.astro';
import SectionHead from '../components/SectionHead.astro';
import FocusCard from '../components/FocusCard.astro';
import WorksCard from '../components/WorksCard.astro';
import PostRow from '../components/PostRow.astro';
import { encodeSlugId } from '../lib/slug';
import { getPublishedPosts, getSortedWorks, pickFeaturedWorks } from '../lib/content';

const posts = await getPublishedPosts();
const recentPosts = posts.slice(0, 4);

const allWorks = await getSortedWorks();
const displayWorks = pickFeaturedWorks(allWorks, 3);

const focusAreas = [
  { key: 'cloud_devops', title: 'クラウド & DevOps',  description: '開発と運用をつなぐ仕組みづくり。継続的デリバリ、可観測性、コスト設計など、サービスを健全に動かし続けるための判断と落とし穴の記録。' },
  { key: 'web_frontend', title: 'Web フロントエンド', description: '読みやすさ・速さ・支援技術での到達しやすさを揃えるための実装メモ。コンポーネント設計、レンダリング戦略、タイポグラフィの細部。' },
  { key: 'embedded_iot', title: '組み込み・IoT',      description: 'センサーとマイコンから、ネットワーク越しのクラウドまで。ハードの制約とソフトの抽象が交わる地点で起きることを書きます。' },
];
---

<SiteLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <!-- Hero -->
  <section class="hero" aria-labelledby="hero-heading">
    <HeroBackdrop />
    <div class="hero__copy">
      <p class="kw-eyebrow hero__eyebrow">vol. {SITE_VOLUME.toLowerCase()} · software · yokohama</p>
      <h1 id="hero-heading" class="hero__title">
        横に渡って、<br /><span class="hero__title-alt">技術</span>を書く。
      </h1>
      <p class="hero__lead no-indent">
        組み込みからクラウド、フロントエンドまでを行き来しながら書いた、実装と設計の手控えです。
        プロトタイプから本番運用まで、手元で試したことを残しています。
      </p>
      <div class="hero__actions">
        <a class="kw-button" href="/blog">記事一覧へ <span class="kw-button-arrow">→</span></a>
        <a class="kw-button kw-button--ghost" href="/about">about_keroway</a>
      </div>
    </div>
    <div class="hero__monogram">
      <Monogram />
    </div>
  </section>
  <div class="kw-divider-pine" aria-hidden="true" role="presentation"></div>

  <!-- Recent posts -->
  <section class="section" aria-labelledby="recent-posts-heading">
    <SectionHead
      jp="最近の記録"
      en="recent posts"
      id="recent-posts-heading"
      action={`see all (${posts.length}) →`}
      actionHref="/blog"
    />
    <div class="posts-list">
      {recentPosts.map((post, i) => (
        <PostRow
          num={(i + 1).toString().padStart(2, '0')}
          href={`/blog/${encodeSlugId(post.id)}/`}
          title={post.data.title}
          description={post.data.description?.trim()}
          pubDate={post.data.pubDate}
          category={post.data.category}
        />
      ))}
    </div>
  </section>

  <!-- Works -->
  {displayWorks.length > 0 && (
    <section class="section" aria-labelledby="works-heading">
      <SectionHead
        jp="制作物"
        en="works"
        id="works-heading"
        action="see all →"
        actionHref="/works"
      />
      <ul class="works-grid">
        {displayWorks.map((work) => (
          <li>
            <WorksCard work={work} />
          </li>
        ))}
      </ul>
    </section>
  )}

  <!-- Focus areas -->
  <section class="section" aria-labelledby="focus-areas-heading">
    <SectionHead jp="専門分野" en="focus areas" id="focus-areas-heading" />
    <div class="focus-grid">
      {focusAreas.map((area, i) => (
        <FocusCard index={i} key={area.key} title={area.title} description={area.description} />
      ))}
    </div>
  </section>
</SiteLayout>

<style>
  /* Hero */
  .hero {
    position: relative;
    isolation: isolate;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--kw-space-12);
    align-items: end;
    margin-bottom: var(--kw-space-8);
    padding-bottom: var(--kw-space-10);
  }
  .hero__eyebrow {
    margin-bottom: var(--kw-space-4);
  }
  .hero__title {
    font-family: var(--kw-font-display);
    font-size: var(--kw-fs-display-lg);
    font-weight: var(--kw-fw-medium);
    line-height: var(--kw-lh-tight);
    letter-spacing: var(--kw-ls-display);
    color: var(--kw-fg-display);
    margin: 0 0 var(--kw-space-6);
  }
  .hero__title-alt { color: var(--kw-fg-link); }
  .hero__lead {
    font-family: var(--kw-font-body);
    font-size: var(--kw-fs-body-lg);
    color: var(--kw-fg-muted);
    margin: 0 0 var(--kw-space-8);
    max-width: 42ch;
    line-height: var(--kw-lh-prose);
  }
  .hero__actions {
    display: flex;
    align-items: center;
    gap: var(--kw-space-5);
    flex-wrap: wrap;
  }
  .hero__monogram {
    align-self: end;
  }

  /* Sections */
  .section {
    margin-bottom: var(--kw-space-20);
  }
  .kw-divider-pine {
    margin-bottom: var(--kw-space-16);
  }

  /* Post numbered rows */
  .posts-list {
    display: flex;
    flex-direction: column;
  }

  /* Works grid */
  .works-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--kw-space-6);
    padding: 0;
    margin: 0;
  }
  .works-grid li {
    min-width: 0;
  }

  /* Focus grid */
  .focus-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--kw-space-10);
  }

  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
    }
    .hero__title {
      font-size: var(--kw-fs-display-sm);
    }
    .hero__monogram {
      display: none;
    }
    .focus-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 640px) {
    .focus-grid {
      grid-template-columns: 1fr;
    }
    .hero__title {
      font-size: var(--kw-fs-h1);
    }
  }

  /* Scroll-in animation */
  .scroll-hidden {
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 350ms var(--kw-easing, ease-out),
      transform 350ms var(--kw-easing, ease-out);
  }
  .scroll-visible {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .scroll-hidden {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  function initScrollAnimation(): void {
    // prefers-reduced-motion チェック
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // アニメーション対象: hero + .section
    const targets = document.querySelectorAll<HTMLElement>('.hero, .section');

    if (prefersReduced) {
      // モーション無効時は即表示（クラスを付けない）
      targets.forEach((el) => {
        el.classList.remove('scroll-hidden', 'scroll-visible');
      });
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('scroll-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      {
        threshold: 0.1,
        rootMargin: '0px 0px -40px 0px',
      }
    );

    targets.forEach((el) => {
      el.classList.add('scroll-hidden');
      observer.observe(el);
    });
  }

  // 初回ロード
  initScrollAnimation();

  // Astro View Transitions での再初期化
  document.addEventListener('astro:page-load', () => {
    initScrollAnimation();
  });
</script>
