---
import SiteLayout from '../layouts/SiteLayout.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import Monogram from '../components/Monogram.astro';
import SectionHead from '../components/SectionHead.astro';
import FocusCard from '../components/FocusCard.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .slice()
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const recentPosts = posts.slice(0, 4);

const focusAreas = [
  { key: 'cloud_devops', title: 'クラウド & DevOps',  description: 'GCP やオンプレ環境を組み合わせた運用ノウハウ、CI/CD、監視などの構築メモをまとめます。' },
  { key: 'frontend_ui',  title: 'フロントエンド UI',  description: 'Astro を中心に、使いやすさとパフォーマンスを両立する UI デザインや実装の記録。' },
  { key: 'embedded_iot', title: '組み込み・IoT',      description: 'Arduino / ESP32 などのマイコン検証や、クラウド連携を含めたプロトタイピングの学び。' },
];
---

<SiteLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <!-- Hero -->
  <section class="hero" aria-labelledby="hero-heading">
    <div class="hero__copy">
      <p class="kw-eyebrow hero__eyebrow">vol. xviii · software · 横浜</p>
      <h1 id="hero-heading" class="hero__title">
        技術と<span class="hero__title-alt">記録</span>の<br />二十年。
      </h1>
      <p class="hero__lead no-indent">
        組み込みからクラウド、フロントエンドまで、領域を横断する実装の記録。
        プロトタイプから本番運用まで、二十年以上の開発経験を通じて得た知見と実装パターンを綴っている。
      </p>
      <div class="hero__actions">
        <a class="kw-button" href="/blog">記事一覧へ <span class="kw-button-arrow">→</span></a>
        <a class="kw-button kw-button--ghost" href="/about">about_keroway</a>
      </div>
    </div>
    <div class="hero__monogram">
      <Monogram />
    </div>
  </section>

  <!-- Recent posts -->
  <section class="section" aria-labelledby="recent-posts-heading">
    <SectionHead
      jp="最近の記録"
      en="recent posts"
      id="recent-posts-heading"
      action={`see all (${posts.length}) →`}
      actionHref="/blog"
    />
    <div class="posts-list">
      {recentPosts.map((post, i) => {
        const description = post.data.description?.trim();
        const encodedSlug = post.id.split('/').map((segment) => encodeURIComponent(segment)).join('/');
        const num = (i + 1).toString().padStart(2, '0');
        return (
          <article class="post-row">
            <a href={`/blog/${encodedSlug}/`} class="post-row__link">
              <span class="post-row__num kw-numeral kw-tabular">{num}</span>
              <div class="post-row__body">
                <p class="kw-eyebrow post-row__meta no-indent">
                  <FormattedDate date={post.data.pubDate} />
                  {post.data.category && <span>· {post.data.category}</span>}
                </p>
                <h3 class="post-row__title">{post.data.title}</h3>
                {description && <p class="post-row__desc no-indent">{description}</p>}
              </div>
              <span class="post-row__arrow" aria-hidden="true">→</span>
            </a>
          </article>
        );
      })}
    </div>
  </section>

  <!-- Focus areas -->
  <section class="section" aria-labelledby="focus-areas-heading">
    <SectionHead jp="専門分野" en="focus areas" id="focus-areas-heading" />
    <div class="focus-grid">
      {focusAreas.map((area, i) => (
        <FocusCard index={i} key={area.key} title={area.title} description={area.description} />
      ))}
    </div>
  </section>
</SiteLayout>

<style>
  /* Hero */
  .hero {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--kw-space-12);
    align-items: end;
    margin-bottom: var(--kw-space-20);
    padding-bottom: var(--kw-space-10);
    border-bottom: 1px solid var(--kw-rule);
  }
  .hero__eyebrow {
    margin-bottom: var(--kw-space-4);
  }
  .hero__title {
    font-family: var(--kw-font-display);
    font-size: var(--kw-fs-display-lg);
    font-weight: var(--kw-fw-medium);
    line-height: var(--kw-lh-tight);
    letter-spacing: var(--kw-ls-display);
    color: var(--kw-fg-display);
    margin: 0 0 var(--kw-space-6);
  }
  .hero__title-alt { color: var(--kw-fg-link); }
  .hero__lead {
    font-family: var(--kw-font-body);
    font-size: var(--kw-fs-body-lg);
    color: var(--kw-fg-muted);
    margin: 0 0 var(--kw-space-8);
    max-width: 42ch;
    line-height: var(--kw-lh-prose);
  }
  .hero__actions {
    display: flex;
    align-items: center;
    gap: var(--kw-space-5);
    flex-wrap: wrap;
  }
  .hero__monogram {
    align-self: end;
  }

  /* Sections */
  .section {
    margin-bottom: var(--kw-space-20);
  }

  /* Post numbered rows */
  .posts-list {
    display: flex;
    flex-direction: column;
  }
  .post-row__link {
    display: grid;
    grid-template-columns: 56px 1fr auto;
    gap: var(--kw-space-6);
    align-items: baseline;
    padding: var(--kw-space-6) 0;
    border-bottom: 1px solid var(--kw-rule-soft);
    text-decoration: none;
    color: inherit;
    border-bottom-width: 1px;
    transition: background var(--kw-duration-fast) var(--kw-easing);
  }
  .post-row__link:hover {
    border-bottom-color: var(--kw-rule);
  }
  .post-row__link:hover .post-row__title {
    color: var(--kw-fg-link);
  }
  .post-row__num {
    font-size: 22px;
  }
  .post-row__meta {
    margin-bottom: var(--kw-space-2);
    color: var(--kw-fg-muted);
  }
  .post-row__title {
    font-family: var(--kw-font-display);
    font-size: var(--kw-fs-h3);
    font-weight: var(--kw-fw-medium);
    color: var(--kw-fg-display);
    letter-spacing: -0.01em;
    margin: 0 0 var(--kw-space-1);
    line-height: var(--kw-lh-snug);
    transition: color var(--kw-duration-fast) var(--kw-easing);
  }
  .post-row__desc {
    font-size: var(--kw-fs-body-sm);
    color: var(--kw-fg-muted);
    line-height: var(--kw-lh-normal);
    margin: 0;
    max-width: 60ch;
  }
  .post-row__arrow {
    font-family: var(--kw-font-display);
    font-size: 20px;
    color: var(--kw-fg-link);
    align-self: center;
  }

  /* Focus grid */
  .focus-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--kw-space-10);
  }

  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
    }
    .hero__title {
      font-size: var(--kw-fs-display-sm);
    }
    .hero__monogram {
      display: none;
    }
    .focus-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 640px) {
    .post-row__link {
      grid-template-columns: 40px 1fr auto;
      gap: var(--kw-space-4);
    }
    .focus-grid {
      grid-template-columns: 1fr;
    }
    .hero__title {
      font-size: var(--kw-fs-h1);
    }
  }

  /* Scroll-in animation */
  .scroll-hidden {
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 350ms var(--kw-easing, ease-out),
      transform 350ms var(--kw-easing, ease-out);
  }
  .scroll-visible {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .scroll-hidden {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  function initScrollAnimation(): void {
    // prefers-reduced-motion チェック
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // アニメーション対象: hero + .section
    const targets = document.querySelectorAll<HTMLElement>('.hero, .section');

    if (prefersReduced) {
      // モーション無効時は即表示（クラスを付けない）
      targets.forEach((el) => {
        el.classList.remove('scroll-hidden', 'scroll-visible');
      });
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('scroll-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      {
        threshold: 0.1,
        rootMargin: '0px 0px -40px 0px',
      }
    );

    targets.forEach((el) => {
      el.classList.add('scroll-hidden');
      observer.observe(el);
    });
  }

  // 初回ロード
  initScrollAnimation();

  // Astro View Transitions での再初期化
  document.addEventListener('astro:page-load', () => {
    initScrollAnimation();
  });
</script>
