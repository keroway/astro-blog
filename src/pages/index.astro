---
import SiteLayout from '../layouts/SiteLayout.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog'))
	.slice()
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const recentPosts = posts.slice(0, 3);

const focusAreas = [
	{
		title: 'クラウド & DevOps',
		description: 'GCP やオンプレ環境を組み合わせた運用ノウハウ、CI/CD、監視などの構築メモをまとめます。',
	},
	{
		title: 'フロントエンド UI',
		description: 'Astro を中心に、使いやすさとパフォーマンスを両立する UI デザインや実装の記録。',
	},
	{
		title: '組み込み・IoT',
		description: 'Arduino / ESP32 などのマイコン検証や、クラウド連携を含めたプロトタイピングの学び。',
	},
];

const learningTopics = [
	'AI エージェントや LLM を活用した開発フロー改善',
	'Astro 5 のトランジションや Islands の実践',
	'組み込みデバイスとクラウドをつなぐハイブリッド構成',
];
---

<SiteLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<section class="hero">
		<div class="hero__content">
			<div class="hero__avatar" aria-hidden="true">K</div>
			<div class="hero__copy">
				<p class="hero__eyebrow">Software Engineer · Yokohama, Japan</p>
				<h1>
					テクノロジーの「気になる」を
					<span>素早く記録</span>
					して共有するブログ
				</h1>
				<p class="hero__lead">
					組み込みからクラウド、フロントエンドまで 20 年以上の経験で得た知見や試行錯誤をまとめています。
					業務で扱う前の実験記録や、Qiita / Zenn に載せる前の下書きを公開する場所です。
				</p>
				<div class="hero__actions">
					<a class="button" href="/blog">最新の記事を見る</a>
					<a class="button button--ghost" href="/about">プロフィールを読む</a>
				</div>
			</div>
		</div>
		<ul class="hero__tags" aria-label="主な関心領域">
			<li><span class="chip">Embedded</span></li>
			<li><span class="chip">Web Frontend</span></li>
			<li><span class="chip">Cloud Infra</span></li>
			<li><span class="chip">Mobile Apps</span></li>
		</ul>
	</section>

	<section class="recent-posts" aria-labelledby="recent-posts-heading">
		<header class="section-heading">
			<h2 id="recent-posts-heading">最新の記事</h2>
			<a class="button button--ghost recent-posts__all-link" href="/blog">すべての記事を見る</a>
		</header>
		<div class="recent-posts__grid">
			{
				recentPosts.map((post) => {
					const description = post.data.description?.trim();
					const encodedSlug = post.slug.split('/').map((segment) => encodeURIComponent(segment)).join('/');
					return (
						<article class="recent-card">
							<a class="recent-card__link" href={`/blog/${encodedSlug}/`}>
								<h3>{post.data.title}</h3>
								<p class="recent-card__summary">
									{description ?? '本文で詳細を解説しています。'}
								</p>
								<p class="recent-card__meta">
									<FormattedDate date={post.data.pubDate} />
									{post.data.category && <span aria-label="カテゴリ" class="recent-card__category">{post.data.category}</span>}
								</p>
							</a>
						</article>
					);
				})
			}
		</div>
	</section>

	<section class="focus-areas" aria-labelledby="focus-areas-heading">
		<header class="section-heading">
			<h2 id="focus-areas-heading">よく書くテーマ</h2>
			<p class="subtle-text">ソフトウェアにまつわる興味範囲を３つの切り口で紹介します。</p>
		</header>
		<div class="focus-areas__grid">
			{
				focusAreas.map((area) => (
					<article class="focus-card">
						<h3>{area.title}</h3>
						<p>{area.description}</p>
					</article>
				))
			}
		</div>
	</section>

	<section class="learning" aria-labelledby="learning-heading">
		<header class="section-heading">
			<h2 id="learning-heading">最近の関心ごと</h2>
			<p class="subtle-text">今取り組んでいるテーマや、今後記事化したい話題です。</p>
		</header>
		<ul class="learning__list">
			{learningTopics.map((topic) => (
				<li>{topic}</li>
			))}
		</ul>
	</section>

	<section class="callout" aria-labelledby="callout-heading">
		<div class="callout__content">
			<h2 id="callout-heading">お気軽にご連絡ください</h2>
			<p>
				ブログの感想やフィードバック、登壇・執筆のご相談などがあれば、以下のリンクからお声がけいただけます。
				X (旧 Twitter) は DM を開放しています。
			</p>
			<ul class="callout__links">
				<li>
					<a class="button" href="https://twitter.com/keroway21" rel="noopener noreferrer" target="_blank">X (Twitter)</a>
					<span class="subtle-text">最新情報や雑多なメモを発信中</span>
				</li>
				<li>
					<a class="button button--ghost" href="https://github.com/keroway" rel="noopener noreferrer" target="_blank">GitHub</a>
					<span class="subtle-text">Issue や Discussions からの連絡も歓迎です</span>
				</li>
			</ul>
			<p class="callout__note">
				※ 具体的な相談窓口（メールアドレスなど）を設ける場合は、この欄に追記してください。
			</p>
		</div>
	</section>
</SiteLayout>

<style>
	.hero {
		display: grid;
		gap: clamp(1.75rem, 4vw, 2.75rem);
		margin-bottom: clamp(2.5rem, 6vw, 4rem);
	}
	.hero__content {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: clamp(1.5rem, 4vw, 2.75rem);
		align-items: center;
		background: var(--surface);
		border-radius: 28px;
		padding: clamp(1.75rem, 4vw, 2.75rem);
		box-shadow: var(--shadow-md);
		border: 1px solid rgba(var(--gray-light), 0.6);
	}
	.hero__avatar {
		width: clamp(88px, 12vw, 120px);
		aspect-ratio: 1;
		display: grid;
		place-items: center;
		font-size: clamp(2.25rem, 5vw, 3rem);
		font-weight: 700;
		color: #fff;
		background: radial-gradient(circle at 30% 30%, #6fa3ff, var(--accent));
		border-radius: 32px;
		box-shadow: var(--shadow-sm);
		text-transform: uppercase;
	}
	.hero__copy h1 {
		margin: 0.25rem 0 1rem;
		font-size: clamp(2.2rem, 5vw, 3.1rem);
		line-height: 1.15;
		color: rgb(var(--black));
	}
	.hero__copy span {
		color: var(--accent);
	}
	.hero__lead {
		margin: 0 0 1.35rem 0;
		color: var(--text-muted);
		font-size: 1.05rem;
		line-height: 1.8;
	}
	.hero__eyebrow {
		margin: 0;
		font-size: 0.95rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: rgba(var(--gray), 0.8);
	}
	.hero__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.85rem;
	}
	.hero__tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.recent-posts {
		margin-bottom: clamp(2.75rem, 6vw, 4rem);
	}
	.recent-posts__grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: clamp(1.5rem, 4vw, 2.25rem);
	}
	.recent-posts__all-link {
		padding-inline: 1rem;
	}
	.recent-card {
		background: var(--surface);
		border-radius: 22px;
		box-shadow: var(--shadow-sm);
		border: 1px solid rgba(var(--gray-light), 0.75);
		transition: transform 150ms ease, box-shadow 150ms ease;
		height: 100%;
	}
	.recent-card__link {
		display: grid;
		gap: 0.75rem;
		padding: clamp(1.35rem, 3vw, 1.8rem);
		text-decoration: none;
		color: inherit;
	}
	.recent-card__link h3 {
		margin: 0;
		font-size: clamp(1.2rem, 3vw, 1.45rem);
		line-height: 1.35;
	}
	.recent-card__summary {
		margin: 0;
		color: var(--text-muted);
		font-size: 0.98rem;
		line-height: 1.6;
	}
	.recent-card__meta {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin: 0;
		font-size: 0.9rem;
		color: rgba(var(--gray), 0.85);
	}
	.recent-card__category {
		display: inline-flex;
		align-items: center;
		padding: 0.2rem 0.65rem;
		border-radius: 999px;
		background: rgba(35, 55, 255, 0.12);
		color: rgb(var(--accent));
		font-weight: 600;
		font-size: 0.8rem;
		letter-spacing: 0.04em;
		text-transform: uppercase;
	}
	.recent-card:hover {
		transform: translateY(-4px);
		box-shadow: var(--shadow-md);
	}

	.focus-areas {
		margin-bottom: clamp(2.75rem, 6vw, 4rem);
	}
	.focus-areas__grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: clamp(1.25rem, 3vw, 2rem);
	}
	.focus-card {
		background: var(--surface);
		padding: clamp(1.35rem, 3vw, 1.9rem);
		border-radius: 20px;
		border: 1px solid rgba(var(--gray-light), 0.75);
		box-shadow: var(--shadow-sm);
		display: grid;
		gap: 0.75rem;
	}
	.focus-card h3 {
		margin: 0;
		font-size: 1.2rem;
		color: rgb(var(--black));
	}
	.focus-card p {
		margin: 0;
		color: var(--text-muted);
		line-height: 1.7;
	}

	.learning {
		margin-bottom: clamp(2.75rem, 6vw, 4.2rem);
	}
	.learning__list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 0.75rem;
	}
	.learning__list li {
		position: relative;
		padding-inline-start: 1.5rem;
		color: rgb(var(--gray-dark));
		line-height: 1.6;
	}
	.learning__list li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0.6em;
		width: 0.55rem;
		height: 0.55rem;
		border-radius: 50%;
		background: var(--accent);
	}

	.callout {
		background: linear-gradient(120deg, rgba(35, 55, 255, 0.12), rgba(35, 55, 255, 0.32));
		border-radius: 28px;
		padding: clamp(2rem, 5vw, 2.75rem);
		box-shadow: var(--shadow-md);
		border: 1px solid rgba(35, 55, 255, 0.15);
	}
	.callout__content {
		display: grid;
		gap: 1.25rem;
	}
	.callout__links {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 1rem;
	}
	.callout__links li {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		align-items: center;
	}
	.callout__note {
		margin: 0;
		font-size: 0.9rem;
		color: rgba(var(--gray), 0.9);
	}

	@media (max-width: 900px) {
		.hero__content {
			grid-template-columns: 1fr;
			text-align: center;
		}
		.hero__avatar {
			justify-self: center;
		}
		.hero__actions {
			justify-content: center;
		}
		.recent-posts__grid {
			grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		}
	}

	@media (max-width: 640px) {
		.hero__tags {
			justify-content: center;
		}
		.recent-posts__grid {
			grid-template-columns: 1fr;
		}
	}
</style>
