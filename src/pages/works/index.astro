---
import SiteLayout from "../../layouts/SiteLayout.astro";
import WorksCard from "../../components/WorksCard.astro";
import SectionHead from "../../components/SectionHead.astro";
import Monogram from "../../components/Monogram.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../../consts";
import { getSortedWorks } from "../../lib/content";

const works = await getSortedWorks();
---

<SiteLayout title={`Works | ${SITE_TITLE}`} description={SITE_DESCRIPTION} mainClass="works-index">
  <Fragment slot="head">
    <link rel="alternate" type="application/rss+xml" title="Works RSS" href="/works/rss.xml" />
  </Fragment>

  <!-- Hero -->
  <section class="works-hero" aria-labelledby="works-hero-heading">
    <div class="works-hero__copy">
      <p class="kw-eyebrow works-hero__eyebrow">Works / Tools</p>
      <h1 id="works-hero-heading" class="works-hero__title">
        作ったものを、<br />まとめてます。
      </h1>
      <p class="works-hero__lead no-indent">
        各ツールやプロダクトについて、背景・技術構成・公開先を整理したページです。
        ブログ記事より短く、LP より詳しい、その中間くらいの粒度感です。
      </p>
    </div>
    <div class="works-hero__aside">
      <p class="works-hero__count kw-numeral kw-tabular">{works.length.toString().padStart(2, "0")}</p>
      <p class="kw-eyebrow no-indent">published entries</p>
      <Monogram tag="Works Index" />
    </div>
  </section>

  <!-- Works list -->
  <section aria-labelledby="works-list-heading">
    <SectionHead
      jp="Project Index"
      en="all works"
      id="works-list-heading"
      action="RSS →"
      actionHref="/works/rss.xml"
    />
    <ul class="works-grid">
      {works.map((work) => (
        <li>
          <WorksCard work={work} />
        </li>
      ))}
    </ul>
  </section>
</SiteLayout>

<style>
  .works-index {
    width: min(var(--kw-content-max), 100%);
  }

  /* Hero */
  .works-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) auto;
    gap: var(--kw-space-12);
    align-items: end;
    margin-bottom: var(--kw-space-20);
    padding-bottom: var(--kw-space-10);
    border-bottom: 1px solid var(--kw-rule);
  }
  .works-hero__eyebrow {
    margin-bottom: var(--kw-space-4);
  }
  .works-hero__title {
    font-family: var(--kw-font-display);
    font-size: var(--kw-fs-display-lg);
    font-weight: var(--kw-fw-medium);
    line-height: var(--kw-lh-tight);
    letter-spacing: var(--kw-ls-display);
    color: var(--kw-fg-display);
    margin: 0 0 var(--kw-space-6);
  }
  .works-hero__lead {
    font-size: var(--kw-fs-body-lg);
    color: var(--kw-fg-muted);
    max-width: 44ch;
    line-height: var(--kw-lh-prose);
    margin: 0;
  }

  .works-hero__aside {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--kw-space-3);
  }
  .works-hero__count {
    font-size: clamp(48px, 8vw, 80px);
    color: var(--kw-fg-display);
    line-height: 1;
    margin: 0;
    text-indent: 0;
  }

  /* Works grid */
  .works-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--kw-space-6);
    padding: 0;
    margin: 0;
  }
  .works-grid li {
    min-width: 0;
  }

  @media (max-width: 900px) {
    .works-hero {
      grid-template-columns: 1fr;
    }
    .works-hero__title {
      font-size: var(--kw-fs-display-sm);
    }
    .works-hero__aside {
      align-items: flex-start;
    }
  }
</style>
