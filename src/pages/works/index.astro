---
import { getCollection } from "astro:content";
import SiteLayout from "../../layouts/SiteLayout.astro";
import WorksCard from "../../components/WorksCard.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../../consts";

const works = (await getCollection("works"))
	.slice()
	.sort((a, b) => (b.data.updatedAt ?? b.data.createdAt).valueOf() - (a.data.updatedAt ?? a.data.createdAt).valueOf());
---

<SiteLayout title={`${SITE_TITLE} | Works`} description={SITE_DESCRIPTION} mainClass="works-index">
	<Fragment slot="head">
		<link rel="alternate" type="application/rss+xml" title="Works RSS" href="/works/rss.xml" />
	</Fragment>

	<section class="works-hero">
		<div class="works-hero__copy">
			<p class="works-hero__eyebrow">Works / Tools</p>
			<h1>実装したものを、<br />公開導線ごと整理する。</h1>
			<p>
				個別のツールやプロダクトについて、背景・技術構成・公開先をまとめています。記事より短く、LP より文脈が分かる中間レイヤーです。
			</p>
		</div>
		<div class="works-hero__aside">
			<p class="works-hero__count">{works.length.toString().padStart(2, "0")}</p>
			<p class="works-hero__label">Published entries</p>
			<a class="button button--ghost" href="/works/rss.xml">RSS を購読</a>
		</div>
	</section>

	<section aria-labelledby="works-list-heading">
		<header class="section-heading works-section-heading">
			<h2 id="works-list-heading">Project Index</h2>
			<p class="subtle-text">status と公開先を併記した一覧</p>
		</header>
		<ul class="works-grid">
			{
				works.map((work) => (
					<li>
						<WorksCard work={work} />
					</li>
				))
			}
		</ul>
	</section>
</SiteLayout>

<style>
	:global(body) {
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.7), rgba(250, 250, 250, 0.96)),
			repeating-linear-gradient(
				90deg,
				transparent 0,
				transparent 40px,
				rgba(29, 78, 216, 0.04) 40px,
				rgba(29, 78, 216, 0.04) 41px
			),
			linear-gradient(var(--gray-gradient)) no-repeat;
		background-size: auto, auto, 100% 540px;
		background-color: var(--surface-muted);
	}
	.works-index {
		width: min(1100px, 100%);
		padding-block-start: clamp(2rem, 5vw, 4rem);
	}
	.works-hero {
		display: grid;
		grid-template-columns: minmax(0, 1.5fr) minmax(240px, 0.7fr);
		gap: clamp(1.25rem, 3vw, 2rem);
		margin-bottom: clamp(2.5rem, 6vw, 3.75rem);
	}
	.works-hero__copy,
	.works-hero__aside {
		background: rgba(255, 255, 255, 0.82);
		border: 1px solid rgba(var(--gray), 0.1);
		box-shadow: var(--shadow-md);
		border-radius: 24px;
		backdrop-filter: blur(8px);
	}
	.works-hero__copy {
		padding: clamp(1.8rem, 4vw, 3rem);
	}
	.works-hero__eyebrow {
		margin: 0 0 0.8rem;
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: rgba(var(--gray), 0.75);
	}
	.works-hero h1 {
		margin: 0 0 1rem;
		font-size: clamp(2.2rem, 6vw, 3.4rem);
		line-height: 1.05;
	}
	.works-hero__copy p:last-child {
		margin: 0;
		max-width: 54ch;
		color: var(--text-muted);
	}
	.works-hero__aside {
		padding: clamp(1.5rem, 4vw, 2rem);
		display: grid;
		align-content: space-between;
		gap: 1rem;
	}
	.works-hero__count {
		margin: 0;
		font-size: clamp(3rem, 10vw, 4.8rem);
		line-height: 1;
		font-weight: 800;
		color: rgb(var(--black));
	}
	.works-hero__label {
		margin: 0;
		color: var(--text-muted);
	}
	.works-section-heading {
		align-items: end;
	}
	.works-grid {
		list-style: none;
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: clamp(1.25rem, 3vw, 2rem);
		padding: 0;
		margin: 0;
	}
	.works-grid li {
		min-width: 0;
	}
	@media (max-width: 800px) {
		.works-hero {
			grid-template-columns: 1fr;
		}
	}
</style>
