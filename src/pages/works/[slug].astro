---
import { getCollection, render } from "astro:content";
import WorkEntryLayout from "../../layouts/WorkEntryLayout.astro";
import type { WorksEntry } from "../../types/content";

export async function getStaticPaths() {
	const works = await getCollection("works");
	return works.map((work) => ({
		params: { slug: work.id },
		props: work,
	}));
}

type Props = WorksEntry;

const work = Astro.props;
const { Content } = await render(work);
---

<WorkEntryLayout {...work.data} id={work.id}>
	<Content />
</WorkEntryLayout>
