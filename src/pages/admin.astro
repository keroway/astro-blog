---
// Sveltia CMS — @sveltia/cms npm パッケージからバンドルされる静的 SPA (ADR 0016)。
// Astro バージョンに依存しないため、Astro メジャーアップ時もここを変更不要。
// 設定: public/admin/config.yml
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- robots: admin は検索インデックス不要 (vercel.json の X-Robots-Tag と二重防衛) -->
    <meta name="robots" content="noindex, nofollow" />
    <title>keroway CMS</title>
    <link rel="stylesheet" href="/admin/theme.css" />
    <script>
      import CMS from "@sveltia/cms";
      import { parse, stringify } from "yaml";

      const normalizeDates = (value: any): any => {
        if (value instanceof Date) {
          return value.toISOString().slice(0, 10);
        }

        if (Array.isArray(value)) {
          return value.map(normalizeDates);
        }

        if (value && typeof value === "object") {
          return Object.fromEntries(
            Object.entries(value).map(([key, childValue]) => [
              key,
              normalizeDates(childValue),
            ]),
          );
        }

        return value;
      };

      const splitFrontmatter = (text: string) => {
        const normalized = text.replace(/^\uFEFF/, "");

        if (!normalized.startsWith("---\n")) {
          return { frontmatter: {}, body: normalized };
        }

        const end = normalized.indexOf("\n---", 4);

        if (end === -1) {
          return { frontmatter: {}, body: normalized };
        }

        const frontmatterText = normalized.slice(4, end);
        const bodyStart = normalized.startsWith("\n", end + 4) ? end + 5 : end + 4;

        return {
          frontmatter: normalizeDates(parse(frontmatterText) ?? {}),
          body: normalized.slice(bodyStart),
        };
      };

      CMS.registerCustomFormat("mdoc", "mdoc", {
        fromFile: (text) => {
          const { frontmatter, body } = splitFrontmatter(text);

          return { ...frontmatter, body };
        },
        toFile: (data) => {
          const { body = "", ...frontmatter } = normalizeDates(data ?? {});
          const yaml = stringify(frontmatter, {
            lineWidth: 100,
            sortMapEntries: false,
          }).trim();

          return `---\n${yaml}\n---\n\n${body}`;
        },
      });

      const response = await fetch("/admin/config.yml");
      const config = parse(await response.text());

      config.load_config_file = false;
      config.app_title = "keroway CMS";
      config.site_url = "https://keroway.com";
      config.display_url = "keroway.com";
      config.show_preview_links = true;
      config.collections = config.collections.map((collection: any) =>
        ["blog", "works"].includes(collection.name)
          ? { ...collection, format: "mdoc" }
          : collection,
      );

      const labelRules = [
        { pattern: /^Sveltia CMS$/u, label: "keroway CMS" },
        {
          pattern: /^Work with Local Repository$/u,
          label: "ローカルリポジトリで編集",
        },
        { pattern: /^Sign In with .*GitHub/u, label: "GitHub でサインイン" },
        {
          pattern: /^Sign In Using Access Token$/u,
          label: "アクセストークンでサインイン",
        },
        { pattern: /^Welcome to/u, label: "keroway CMS へようこそ" },
        {
          pattern: /^Once prompted, select the root directory/u,
          label:
            "表示されたダイアログで astro-blog リポジトリのルートディレクトリを選択してください。",
        },
      ];

      const actionRules = [
        {
          type: "primary",
          pattern:
            /ローカルリポジトリ|Work with Local Repository|保存|Save|作成|New|Create|投稿|Submit/iu,
        },
        {
          type: "danger",
          pattern: /削除|Delete|破棄|Discard|Remove|リセット|Reset/iu,
        },
        {
          type: "secondary",
          pattern:
            /GitHub|プレビュー|Preview|公開|Publish|アップロード|Upload|メディア|Media/iu,
        },
        {
          type: "subtle",
          pattern:
            /Access Token|キャンセル|Cancel|閉じる|Close|戻る|Back|編集|Edit/iu,
        },
      ];

      const isLoginScreen = () =>
        [...document.querySelectorAll("button, a")].some((element) =>
          /Work with Local Repository|ローカルリポジトリで編集|Sign In/iu.test(
            element.textContent?.replace(/\s+/g, " ").trim() ?? "",
          ),
        );

      const localizeLoginText = () => {
        if (!isLoginScreen()) return;

        document
          .querySelectorAll<HTMLElement>("button, a, h1, h2, h3, p, [role='none']")
          .forEach((element) => {
            const text = element.textContent?.replace(/\s+/g, " ").trim() ?? "";
            const matched = labelRules.find(({ pattern }) => pattern.test(text));

            if (matched && element.textContent !== matched.label) {
              element.textContent = matched.label;
            }
          });
      };

      const renderLoginGuide = () => {
        const note = document.querySelector(".keroway-admin-shell-note");

        if (!isLoginScreen()) {
          note?.remove();
          return;
        }

        if (note) return;

        const nextNote = document.createElement("aside");
        nextNote.className = "keroway-admin-shell-note";
        nextNote.setAttribute("aria-label", "CMS の使い方");
        nextNote.innerHTML = `<strong>推奨: ローカルリポジトリで編集</strong><span>通常は「ローカルリポジトリで編集」を選び、astro-blog のルートを指定します。GitHub ログインは本番環境用です。</span>`;
        document.body.append(nextNote);
      };

      const classifyAdminActions = () => {
        localizeLoginText();
        renderLoginGuide();

        document
          .querySelectorAll<HTMLButtonElement | HTMLAnchorElement>(
            'button, [role="button"], a',
          )
          .forEach((element) => {
            const text =
              element.textContent?.replace(/\s+/g, " ").trim() ||
              element.getAttribute("aria-label") ||
              element.getAttribute("title") ||
              "";
            const matched = actionRules.find(({ pattern }) => pattern.test(text));

            if (matched) {
              element.dataset.kerowayAdminAction = matched.type;
            }
          });
      };

      CMS.init({ config });

      const observer = new MutationObserver(classifyAdminActions);
      observer.observe(document.body, { childList: true, subtree: true });
      classifyAdminActions();
    </script>
  </head>
  <body>
    <!-- 設定は public/admin/config.yml で管理。 -->
  </body>
</html>
