    <meta name="robots" content="noindex, nofollow" />
    <title>keroway CMS</title>
    <script
      src="https://unpkg.com/@sveltia/cms/dist/sveltia-cms.js"
      type="module"
    ></script>
  </head>
  <body>
    <!-- 設定は public/admin/config.yml で管理。 -->
  </body>
</html>
