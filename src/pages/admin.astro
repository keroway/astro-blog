---
// Sveltia CMS — Astro によってバンドルされるクライアントサイド SPA。
// @sveltia/cms と yaml は package.json の devDependencies で管理。
// 設定: public/admin/config.yml
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- robots: admin は検索インデックス不要 (vercel.json の X-Robots-Tag と二重防衛) -->
    <meta name="robots" content="noindex, nofollow" />
    <title>keroway CMS</title>
    <script>
      import CMS from "@sveltia/cms";
      import { parse, stringify } from "yaml";

      // eslint-disable-next-line @typescript-eslint/no-explicit-any
      const normalizeDates = (value: unknown): any => {
        if (value instanceof Date) {
          return value.toISOString().slice(0, 10);
        }

        if (Array.isArray(value)) {
          return value.map(normalizeDates);
        }

        if (value && typeof value === "object") {
          return Object.fromEntries(
            Object.entries(value as Record<string, unknown>).map(([key, childValue]) => [
              key,
              normalizeDates(childValue),
            ]),
          );
        }

        return value;
      };

      const splitFrontmatter = (text: string) => {
        const normalized = text.replace(/^\uFEFF/, "");

        if (!normalized.startsWith("---\n")) {
          return { frontmatter: {}, body: normalized };
        }

        const end = normalized.indexOf("\n---", 4);

        if (end === -1) {
          return { frontmatter: {}, body: normalized };
        }

        const frontmatterText = normalized.slice(4, end);
        const bodyStart = normalized.startsWith("\n", end + 4) ? end + 5 : end + 4;

        return {
          frontmatter: normalizeDates(parse(frontmatterText) ?? {}),
          body: normalized.slice(bodyStart),
        };
      };

      CMS.registerCustomFormat("mdoc", "mdoc", {
        fromFile: (text) => {
          const { frontmatter, body } = splitFrontmatter(text);

          return { ...frontmatter, body };
        },
        toFile: (data) => {
          const { body = "", ...frontmatter } = normalizeDates(data ?? {});
          const yaml = stringify(frontmatter, {
            lineWidth: 100,
            sortMapEntries: false,
          }).trim();

          return `---\n${yaml}\n---\n\n${body}`;
        },
      });

      const response = await fetch("/admin/config.yml");
      const config = parse(await response.text());

      config.load_config_file = false;
      // eslint-disable-next-line @typescript-eslint/no-explicit-any
      config.collections = config.collections.map((collection: any) =>
        ["blog", "works"].includes(collection.name)
          ? { ...collection, format: "mdoc" }
          : collection,
      );

      CMS.init({ config });
    </script>
  </head>
  <body>
    <!-- 設定は public/admin/config.yml で管理。 -->
  </body>
</html>
