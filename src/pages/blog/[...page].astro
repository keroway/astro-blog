---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { SITE_TITLE, SITE_DESCRIPTION, categoryLabel } from '../../consts';
import SectionHead from '../../components/SectionHead.astro';
import PostRow from '../../components/PostRow.astro';
import BlogSearch from '../../components/BlogSearch.astro';
import { encodeSlugId } from '../../lib/slug';
import { getPublishedPosts } from '../../lib/content';

export const PAGE_SIZE = 20;

export async function getStaticPaths({ paginate }: { paginate: Function }) {
  const allPosts = await getPublishedPosts();

  // フィルタ UI は全ページで一貫したカテゴリ / 年を表示するため、全記事から収集する。
  const allCategories = [
    ...new Set(allPosts.map((p) => p.data.category).filter(Boolean)),
  ].sort() as string[];
  const allYears = [
    ...new Set(allPosts.map((p) => p.data.pubDate.getFullYear())),
  ].sort((a, b) => b - a);

  return paginate(allPosts, {
    pageSize: PAGE_SIZE,
    props: { allCategories, allYears },
  });
}

const { page, allCategories, allYears } = Astro.props as {
  page: {
    data: Awaited<ReturnType<typeof getPublishedPosts>>;
    currentPage: number;
    lastPage: number;
    url: { prev?: string; next?: string; current: string };
    total: number;
    start: number;
    end: number;
  };
  allCategories: string[];
  allYears: number[];
};

const posts = page.data;
const showYearFilter = allYears.length >= 2;

const title = page.currentPage === 1
  ? `Blog | ${SITE_TITLE}`
  : `Blog (${page.currentPage}/${page.lastPage}ページ) | ${SITE_TITLE}`;

// SEO: ページ 2 以降は noindex にして正規ページ (/blog/) へ向ける
const isFirstPage = page.currentPage === 1;
const canonicalUrl = isFirstPage ? undefined : new URL('/blog/', Astro.site).href;
---

<SiteLayout title={title} description={SITE_DESCRIPTION} mainClass="blog-index" canonicalUrl={canonicalUrl}>
  {!isFirstPage && (
    <Fragment slot="head">
      <meta name="robots" content="noindex, follow" />
    </Fragment>
  )}
  {page.url.prev && <link rel="prev" href={page.url.prev} slot="head" />}
  {page.url.next && <link rel="next" href={page.url.next} slot="head" />}

  <div data-reveal>
    <SectionHead
      jp="記事一覧"
      en="all posts"
      action="RSS →"
      actionHref="/rss.xml"
    />

    <BlogSearch />

    <div class="filter-bar">
      <div class="filter-group" role="group" aria-label="カテゴリで絞り込む">
        <button
          class="filter-btn filter-btn--active"
          data-filter-type="category"
          data-filter-value=""
          aria-pressed="true"
        >すべて</button>
        {allCategories.map((cat) => (
          <button
            class="filter-btn"
            data-filter-type="category"
            data-filter-value={cat}
            aria-pressed="false"
          >{categoryLabel(cat)}</button>
        ))}
      </div>
      {showYearFilter && (
        <div class="filter-group filter-group--year" role="group" aria-label="年で絞り込む">
          <button
            class="filter-btn filter-btn--active"
            data-filter-type="year"
            data-filter-value=""
            aria-pressed="true"
          >全年</button>
          {allYears.map((year) => (
            <button
              class="filter-btn"
              data-filter-type="year"
              data-filter-value={String(year)}
              aria-pressed="false"
            >{year}</button>
          ))}
        </div>
      )}
    </div>
  </div>

  <p class="filter-count no-indent" id="filter-count" hidden></p>

  <div class="posts-list" id="posts-list" data-reveal>
    {posts.map((post) => (
      <PostRow
        href={`/blog/${encodeSlugId(post.id)}/`}
        titleTag="h2"
        title={post.data.title}
        description={post.data.description?.trim()}
        pubDate={post.data.pubDate}
        category={categoryLabel(post.data.category)}
        accentNum={true}
        dataYear={String(post.data.pubDate.getFullYear())}
        dataCategory={post.data.category}
      />
    ))}
  </div>

  <p class="empty-message no-indent" id="empty-message" hidden>
    このページに該当する記事がありません。
    <a href="#blog-search-input">全文検索</a>で横断検索するか、他のページもご確認ください。
  </p>

  {page.lastPage > 1 && (
    <nav class="pagination" aria-label="ページナビゲーション">
      <div class="pagination__info">
        <span class="kw-mono pagination__count">
          {page.start + 1}–{page.end + 1} / {page.total} 件
        </span>
        <span class="kw-mono pagination__page">
          {page.currentPage} / {page.lastPage} ページ
        </span>
      </div>
      <div class="pagination__links">
        {page.url.prev ? (
          <a href={page.url.prev} class="kw-button kw-button--ghost pagination__btn">
            ← 新しい記事
          </a>
        ) : (
          <span class="pagination__btn pagination__btn--disabled" aria-disabled="true">← 新しい記事</span>
        )}
        {page.url.next ? (
          <a href={page.url.next} class="kw-button kw-button--ghost pagination__btn">
            古い記事 →
          </a>
        ) : (
          <span class="pagination__btn pagination__btn--disabled" aria-disabled="true">古い記事 →</span>
        )}
      </div>
    </nav>
  )}
</SiteLayout>

<script>
  function initFilter() {
    const params = new URLSearchParams(window.location.search);
    let activeCategory = params.get('category') ?? '';
    let activeYear = params.get('year') ?? '';

    const articles = Array.from(document.querySelectorAll<HTMLElement>('#posts-list .post-row'));
    const countEl = document.getElementById('filter-count');
    const emptyEl = document.getElementById('empty-message');

    function applyFilter() {
      let visible = 0;
      articles.forEach((article) => {
        const cat = article.dataset.category ?? '';
        const year = article.dataset.year ?? '';
        const catMatch = activeCategory === '' || cat === activeCategory;
        const yearMatch = activeYear === '' || year === activeYear;
        const show = catMatch && yearMatch;
        article.hidden = !show;
        if (show) visible++;
      });

      const isFiltered = activeCategory !== '' || activeYear !== '';

      if (countEl) {
        countEl.hidden = !isFiltered;
        countEl.textContent = `${visible} 件`;
      }
      if (emptyEl) {
        emptyEl.hidden = visible > 0;
      }

      let n = 0;
      articles.forEach((article) => {
        if (!article.hidden) {
          n++;
          const numEl = article.querySelector('.post-row__num');
          if (numEl) numEl.textContent = n.toString().padStart(2, '0');
        }
      });
    }

    function updateButtons() {
      document.querySelectorAll<HTMLButtonElement>('[data-filter-type="category"]').forEach((btn) => {
        const active = btn.dataset.filterValue === activeCategory;
        btn.classList.toggle('filter-btn--active', active);
        btn.setAttribute('aria-pressed', active ? 'true' : 'false');
      });
      document.querySelectorAll<HTMLButtonElement>('[data-filter-type="year"]').forEach((btn) => {
        const active = btn.dataset.filterValue === activeYear;
        btn.classList.toggle('filter-btn--active', active);
        btn.setAttribute('aria-pressed', active ? 'true' : 'false');
      });
    }

    function pushState() {
      const p = new URLSearchParams();
      if (activeCategory) p.set('category', activeCategory);
      if (activeYear) p.set('year', activeYear);
      const qs = p.toString();
      history.pushState({}, '', qs ? `?${qs}` : window.location.pathname);
    }

    document.querySelectorAll<HTMLButtonElement>('[data-filter-type]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const type = btn.dataset.filterType!;
        const value = btn.dataset.filterValue!;
        if (type === 'category') activeCategory = value;
        if (type === 'year') activeYear = value;
        pushState();
        updateButtons();
        applyFilter();
      });
    });

    updateButtons();
    applyFilter();
  }

  initFilter();
  document.addEventListener('astro:after-swap', initFilter);
</script>

<style>
  .blog-index {
    width: min(var(--kw-content-max), 100%);
  }

  .filter-bar {
    display: flex;
    flex-direction: column;
    gap: var(--kw-space-3);
    margin-bottom: var(--kw-space-6);
  }

  .filter-group {
    display: flex;
    flex-wrap: wrap;
    gap: var(--kw-space-2);
  }

  .filter-btn {
    font-family: var(--kw-font-mono);
    font-size: var(--kw-fs-mono-sm);
    padding: var(--kw-space-2) var(--kw-space-4);
    border: 1px solid var(--kw-rule-soft);
    border-radius: var(--kw-radius-sm);
    background: transparent;
    color: var(--kw-fg-muted);
    cursor: pointer;
    transition: border-color var(--kw-duration-fast) var(--kw-easing),
                color var(--kw-duration-fast) var(--kw-easing),
                background var(--kw-duration-fast) var(--kw-easing);
  }

  .filter-btn:hover {
    border-color: var(--kw-rule);
    color: var(--kw-fg);
  }

  .filter-btn--active {
    border-color: var(--kw-accent);
    color: var(--kw-accent);
    background: color-mix(in srgb, var(--kw-accent) 8%, transparent);
  }

  .filter-btn:focus-visible {
    outline: 2px solid var(--kw-blue);
    outline-offset: 3px;
  }

  .filter-count {
    font-family: var(--kw-font-mono);
    font-size: var(--kw-fs-mono-xs);
    color: var(--kw-fg-muted);
    margin-bottom: var(--kw-space-4);
  }

  .empty-message {
    font-size: var(--kw-fs-body-sm);
    color: var(--kw-fg-muted);
    padding: var(--kw-space-10) 0;
    text-align: center;
  }

  .posts-list {
    display: flex;
    flex-direction: column;
  }

  /* ページネーション */
  .pagination {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--kw-space-4);
    margin-top: var(--kw-space-10);
    padding-top: var(--kw-space-8);
    border-top: 1px solid var(--kw-rule);
  }

  .pagination__info {
    display: flex;
    gap: var(--kw-space-4);
    font-size: var(--kw-fs-mono-sm);
    color: var(--kw-fg-muted);
  }

  .pagination__links {
    display: flex;
    gap: var(--kw-space-3);
  }

  .pagination__btn {
    font-family: var(--kw-font-mono);
    font-size: var(--kw-fs-mono-sm);
    padding: var(--kw-space-2) var(--kw-space-4);
  }

  .pagination__btn--disabled {
    display: inline-flex;
    align-items: center;
    padding: var(--kw-space-2) var(--kw-space-4);
    border: 1px solid var(--kw-rule-soft);
    border-radius: var(--kw-radius-sm);
    color: var(--kw-fg-faint);
    font-family: var(--kw-font-mono);
    font-size: var(--kw-fs-mono-sm);
    cursor: default;
    user-select: none;
  }

  @media (max-width: 640px) {
    .pagination {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
