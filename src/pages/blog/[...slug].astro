---
import { render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import type { BlogEntry } from '../../types/content';
import { encodeSlugId } from '../../lib/slug';
import { calculateReadingTime, getPublishedPosts, getRelatedPosts } from '../../lib/content';

export async function getStaticPaths() {
	const sorted = await getPublishedPosts();

	return sorted.map((post, idx) => {
		const prevPost = sorted[idx + 1] ?? null;
		const nextPost = sorted[idx - 1] ?? null;
		const relatedPosts = getRelatedPosts(post, sorted);

		return {
			params: { slug: post.id },
			props: { post, prevPost, nextPost, relatedPosts },
		};
	});
}

type Props = {
	post: BlogEntry;
	prevPost: BlogEntry | null;
	nextPost: BlogEntry | null;
	relatedPosts: BlogEntry[];
};

const { post, prevPost, nextPost, relatedPosts } = Astro.props as Props;
const { Content, headings } = await render(post);

const ogImage = `/og/${encodeSlugId(post.id)}.png`;
const readingTime = post.data.readingTime ?? calculateReadingTime(post.body ?? '');
---

<BlogPost
	{...post.data}
	readingTime={readingTime}
	ogImage={ogImage}
	headings={headings}
	prevPost={prevPost}
	nextPost={nextPost}
	relatedPosts={relatedPosts}
>
	<Content />
</BlogPost>
