---
import { render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import type { BlogEntry } from '../../types/content';
import { encodeSlugId } from '../../lib/slug';
import { calculateReadingTime, getPublishedPosts, getRelatedPosts } from '../../lib/content';

export async function getStaticPaths() {
	const sorted = await getPublishedPosts();

	return sorted.map((post, idx) => {
		const prevPost = sorted[idx + 1] ?? null;
		const nextPost = sorted[idx - 1] ?? null;
		const relatedPosts = getRelatedPosts(post, sorted);
		const series = post.data.series;
		const seriesPosts = series
			? sorted
				.filter((p) => p.data.series === series)
				.sort(
					(a, b) =>
						a.data.pubDate.valueOf() - b.data.pubDate.valueOf() ||
						a.id.localeCompare(b.id)
				)
			: [];
		const seriesIndex = seriesPosts.findIndex((p) => p.id === post.id);
		const seriesNav = series && seriesPosts.length > 1 && seriesIndex >= 0
			? {
					name: series,
					current: seriesIndex + 1,
					total: seriesPosts.length,
					prev: seriesPosts[seriesIndex - 1] ?? null,
					next: seriesPosts[seriesIndex + 1] ?? null,
				}
			: null;

		return {
			params: { slug: post.id },
			props: { post, prevPost, nextPost, relatedPosts, seriesNav },
		};
	});
}

type Props = {
	post: BlogEntry;
	prevPost: BlogEntry | null;
	nextPost: BlogEntry | null;
	relatedPosts: BlogEntry[];
	seriesNav: {
		name: string;
		current: number;
		total: number;
		prev: BlogEntry | null;
		next: BlogEntry | null;
	} | null;
};

const { post, prevPost, nextPost, relatedPosts, seriesNav } = Astro.props as Props;
const { Content, headings } = await render(post);

// ogImage が指定されていればカスタム OG 画像として優先、未指定なら自動生成 (#362)。
const ogImage = post.data.ogImage ?? `/og/${encodeSlugId(post.id)}.png`;
// 読了時間は本文から常に自動算出する (#361)。
const readingTime = calculateReadingTime(post.body ?? '');
---

<BlogPost
	{...post.data}
	readingTime={readingTime}
	ogImage={ogImage}
	headings={headings}
	prevPost={prevPost}
	nextPost={nextPost}
	relatedPosts={relatedPosts}
	seriesNav={seriesNav}
>
	<Content />
</BlogPost>
