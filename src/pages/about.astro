---
import SiteLayout from '../layouts/SiteLayout.astro';
import Monogram from '../components/Monogram.astro';
import SectionHead from '../components/SectionHead.astro';
import FocusCard from '../components/FocusCard.astro';

const skills = {
  languages: ['C', 'C++', 'Python', 'TypeScript', 'Go', 'Dart'],
  domains: ['組み込み / IoT', 'Web Frontend', 'クラウドインフラ', 'モバイルアプリ'],
  tools: ['GCP', 'Arduino', 'Astro', 'Flutter', 'Docker', 'GitHub Actions'],
};

const focusAreas = [
  {
    key: 'embedded_iot',
    title: '組み込み・IoT',
    description:
      'Arduino / ESP32 などを中心に、センサーやアクチュエーターの制御からクラウド連携まで。ハードウェアとソフトウェアを横断する実装が得意領域です。',
  },
  {
    key: 'web_frontend',
    title: 'Web フロントエンド',
    description:
      'Astro を軸に、パフォーマンスとアクセシビリティを両立するコンポーネント設計に取り組んでいます。TypeScript strict モードを前提とした型安全な実装を心がけます。',
  },
  {
    key: 'mobile_app',
    title: 'モバイルアプリ',
    description:
      'Flutter によるクロスプラットフォーム開発を実践。ネイティブコードとのブリッジや、BLE デバイスとの連携経験があります。',
  },
  {
    key: 'cloud_infra',
    title: 'クラウド・インフラ',
    description:
      'GCP を中心に、CI/CD パイプラインの構築や監視・ロギング基盤の整備を担当。オンプレとクラウドを組み合わせたハイブリッド構成の経験も持ちます。',
  },
];

const timeline = [
  { year: '20xx', note: 'TODO: 企業名/役割を記入' },
  { year: '20xx', note: 'TODO: 企業名/役割を記入' },
  { year: '20xx', note: 'TODO: 企業名/役割を記入' },
  { year: '20xx', note: 'TODO: 企業名/役割を記入' },
];
---

<SiteLayout
  title="About"
  description="横浜在住のソフトウェアエンジニア。組み込みからクラウド、フロントエンドまで 20 年以上の開発経験を持ちます。"
  mainClass="about-main"
>
  <!-- Masthead -->
  <section class="masthead" aria-labelledby="profile-heading">
    <div class="masthead__copy">
      <p class="kw-eyebrow masthead__eyebrow">colophon · author</p>
      <!-- TODO: 本名を記入 -->
      <h1 id="profile-heading" class="masthead__title">keroway</h1>
      <p class="masthead__sub">software engineer · yokohama</p>
      <p class="masthead__lead no-indent">
        組み込みからクラウド、フロントエンドまで 20 年以上にわたりソフトウェア開発に携わってきました。
        領域を横断する実装経験を活かし、プロトタイプから本番運用まで幅広く対応します。
      </p>
    </div>
    <div class="masthead__monogram">
      <Monogram tag="Vol. XVIII · 著者紹介" />
    </div>
  </section>

  <!-- Career timeline -->
  <section class="section" aria-labelledby="timeline-heading">
    <SectionHead jp="経歴" en="career timeline" id="timeline-heading" />
    <div class="timeline">
      {timeline.map((item, i) => {
        const num = (i + 1).toString().padStart(2, '0');
        return (
          <div class="timeline-row">
            <span class="timeline-row__num kw-numeral kw-tabular">{num}</span>
            <div class="timeline-row__body">
              <p class="kw-eyebrow timeline-row__year no-indent">{item.year}</p>
              <p class="timeline-row__note no-indent">{item.note}</p>
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <!-- Focus areas -->
  <section class="section" aria-labelledby="focus-areas-heading">
    <SectionHead jp="得意分野" en="focus areas" id="focus-areas-heading" />
    <div class="focus-grid">
      {focusAreas.map((area, i) => (
        <FocusCard index={i} key={area.key} title={area.title} description={area.description} />
      ))}
    </div>
  </section>

  <!-- Stack -->
  <section class="section" aria-labelledby="stack-heading">
    <SectionHead jp="スタック" en="stack" id="stack-heading" />
    <div class="stack-groups">
      {Object.entries({ '言語': skills.languages, '領域': skills.domains, 'ツール・インフラ': skills.tools }).map(([label, items]) => (
        <div class="stack-group">
          <h3 class="kw-eyebrow stack-group__label">{label}</h3>
          <ul class="stack-chips" aria-label={label}>
            {items.map((s) => <li><span class="kw-chip">{s}</span></li>)}
          </ul>
        </div>
      ))}
    </div>
  </section>
</SiteLayout>

<style>
  .about-main {
    width: min(900px, 100%);
  }

  /* Masthead */
  .masthead {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--kw-space-12);
    align-items: end;
    margin-bottom: var(--kw-space-20);
    padding-bottom: var(--kw-space-10);
    border-bottom: 1px solid var(--kw-rule);
  }
  .masthead__eyebrow {
    margin-bottom: var(--kw-space-4);
  }
  .masthead__title {
    font-family: var(--kw-font-display);
    font-size: var(--kw-fs-display-xl);
    font-weight: var(--kw-fw-medium);
    line-height: var(--kw-lh-tight);
    letter-spacing: var(--kw-ls-display);
    color: var(--kw-fg-display);
    margin: 0 0 var(--kw-space-2);
  }
  .masthead__sub {
    font-family: var(--kw-font-mono);
    font-size: var(--kw-fs-mono);
    text-transform: uppercase;
    letter-spacing: var(--kw-ls-eyebrow);
    color: var(--kw-fg-link);
    margin: 0 0 var(--kw-space-6);
    text-indent: 0;
  }
  .masthead__lead {
    color: var(--kw-fg-muted);
    font-size: var(--kw-fs-body-lg);
    line-height: var(--kw-lh-prose);
    max-width: 44ch;
    margin: 0;
  }

  /* Sections */
  .section {
    margin-bottom: var(--kw-space-20);
  }

  /* Timeline */
  .timeline {
    display: flex;
    flex-direction: column;
  }
  .timeline-row {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: var(--kw-space-6);
    align-items: baseline;
    padding: var(--kw-space-6) 0;
    border-bottom: 1px solid var(--kw-rule-soft);
  }
  .timeline-row__num {
    font-size: 22px;
  }
  .timeline-row__year {
    margin-bottom: var(--kw-space-1);
    color: var(--kw-accent);
  }
  .timeline-row__note {
    color: var(--kw-fg);
    margin: 0;
  }

  /* Focus grid */
  .focus-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--kw-space-8);
  }

  /* Stack */
  .stack-groups {
    display: grid;
    gap: var(--kw-space-6);
  }
  .stack-group {
    padding: var(--kw-space-5) 0;
    border-bottom: 1px solid var(--kw-rule-soft);
    display: grid;
    gap: var(--kw-space-3);
  }
  .stack-group:last-child {
    border-bottom: 0;
  }
  .stack-group__label {
    margin: 0;
  }
  .stack-chips {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--kw-space-2);
  }

  @media (max-width: 720px) {
    .masthead {
      grid-template-columns: 1fr;
    }
    .masthead__title {
      font-size: var(--kw-fs-display-sm);
    }
    .masthead__monogram {
      display: none;
    }
    .focus-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
