---
import SiteLayout from '../layouts/SiteLayout.astro';
import Monogram from '../components/Monogram.astro';
import SectionHead from '../components/SectionHead.astro';
import FocusCard from '../components/FocusCard.astro';
import TimelineRow from '../components/TimelineRow.astro';
import { SITE_VOLUME } from '../consts';
import { getFocusAreas } from '../data/focus-areas';

const focusAreas = getFocusAreas([
  'embedded_iot',
  'web_frontend',
  'mobile_app',
  'cloud_devops',
  'ai_engineering',
]);

const skills = {
  languages: ['C', 'C++', 'Python', 'TypeScript', 'Go', 'Dart'],
  domains: focusAreas.map((a) => a.title),
  tools: ['GCP', 'Arduino', 'Astro', 'Flutter', 'Docker', 'GitHub Actions'],
};

const strata = [
  { layer: '物理層', note: '回路、センサー、マイコンの上で動く制御コードを書く。最初に長く居た場所。' },
  { layer: '分散層', note: '複数台のマシンが協調する仕組みを組む。CI/CD、監視、運用の自動化を含む。' },
  { layer: '抽象層', note: '言語処理系、データの形、API の設計など、仕組みの上に乗る規約を扱う。' },
  { layer: '表層',   note: '画面とタイポグラフィ、人が触れる面。最近の主な関心の一つ。' },
  { layer: '生成層', note: 'LLM とエージェントを部品として組み込み、自分のサービスを形にする。いま積もりつつある層。' },
];
---

<SiteLayout
  title="About"
  description="横浜のソフトウェアエンジニア keroway のプロフィール。組み込みからクラウド、フロントエンドまで横断して手を動かしてきた領域、関心、使ってきた道具についてまとめています。"
  mainClass="about-main"
>
  <!-- Masthead -->
  <section class="masthead" aria-labelledby="profile-heading" data-reveal>
    <div class="masthead__copy">
      <p class="kw-eyebrow masthead__eyebrow">colophon · author</p>
      <h1 id="profile-heading" class="masthead__title">keroway</h1>
      <p class="masthead__sub">software engineer · yokohama</p>
      <p class="masthead__lead no-indent">
        組み込みからクラウド、フロントエンドまで、領域を横断しながら手を動かしてきました。
        プロトタイプの試作から、本番運用の地味な調整まで、どちらの側も好んで書いています。
      </p>
    </div>
    <div class="masthead__monogram">
      <Monogram tag={`Vol. ${SITE_VOLUME} · 著者`} />
    </div>
  </section>

  <!-- Strata of interest -->
  <section class="section" aria-labelledby="strata-heading" data-reveal>
    <SectionHead jp="関心の地層" en="strata of interest" id="strata-heading" />
    <div class="timeline">
      {strata.map((item, i) => (
        <TimelineRow
          num={(i + 1).toString().padStart(2, '0')}
          layer={item.layer}
          note={item.note}
        />
      ))}
    </div>
  </section>

  <!-- Focus areas -->
  <section class="section" aria-labelledby="focus-areas-heading" data-reveal>
    <SectionHead jp="得意分野" en="focus areas" id="focus-areas-heading" />
    <div class="focus-grid">
      {focusAreas.map((area, i) => (
        <FocusCard index={i} key={area.key} title={area.title} description={area.description} />
      ))}
    </div>
  </section>

  <!-- Stack -->
  <section class="section" aria-labelledby="stack-heading" data-reveal>
    <SectionHead jp="スタック" en="stack" id="stack-heading" />
    <div class="stack-groups">
      {Object.entries({ '言語': skills.languages, '領域': skills.domains, 'ツール・インフラ': skills.tools }).map(([label, items]) => (
        <div class="stack-group">
          <h3 class="kw-eyebrow-ja stack-group__label">{label}</h3>
          <ul class="stack-chips" aria-label={label}>
            {items.map((s) => <li><span class="kw-chip">{s}</span></li>)}
          </ul>
        </div>
      ))}
    </div>
  </section>
</SiteLayout>

<style>
  .about-main {
    width: min(900px, 100%);
  }

  /* Masthead */
  .masthead {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--kw-space-12);
    align-items: end;
    margin-bottom: var(--kw-space-20);
    padding-bottom: var(--kw-space-10);
    border-bottom: 1px solid var(--kw-rule);
  }
  .masthead__eyebrow {
    margin-bottom: var(--kw-space-4);
  }
  .masthead__title {
    font-family: var(--kw-font-display);
    font-size: var(--kw-fs-display-xl);
    font-weight: var(--kw-fw-medium);
    line-height: var(--kw-lh-tight);
    letter-spacing: var(--kw-ls-display);
    color: var(--kw-fg-display);
    margin: 0 0 var(--kw-space-2);
  }
  .masthead__sub {
    font-family: var(--kw-font-mono);
    font-size: var(--kw-fs-mono);
    text-transform: uppercase;
    letter-spacing: var(--kw-ls-eyebrow);
    color: var(--kw-fg-link);
    margin: 0 0 var(--kw-space-6);
    text-indent: 0;
  }
  .masthead__lead {
    color: var(--kw-fg-muted);
    font-size: var(--kw-fs-body-lg);
    line-height: var(--kw-lh-prose);
    max-width: 44ch;
    margin: 0;
  }

  /* Sections */
  .section {
    margin-bottom: var(--kw-space-20);
  }

  /* Timeline */
  .timeline {
    display: flex;
    flex-direction: column;
  }

  /* Focus grid */
  .focus-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--kw-space-8);
  }

  /* Stack */
  .stack-groups {
    display: grid;
    gap: var(--kw-space-6);
  }
  .stack-group {
    padding: var(--kw-space-5) 0;
    border-bottom: 1px solid var(--kw-rule-soft);
    display: grid;
    gap: var(--kw-space-3);
  }
  .stack-group:last-child {
    border-bottom: 0;
  }
  .stack-group__label {
    margin: 0;
  }
  .stack-chips {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--kw-space-2);
  }

  @media (max-width: 720px) {
    .masthead {
      grid-template-columns: 1fr;
    }
    .masthead__title {
      font-size: var(--kw-fs-display-sm);
    }
    .masthead__monogram {
      display: none;
    }
    .focus-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
