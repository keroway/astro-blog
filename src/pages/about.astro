---
import SiteLayout from '../layouts/SiteLayout.astro';
import Monogram from '../components/Monogram.astro';
import SectionHead from '../components/SectionHead.astro';
import FocusCard from '../components/FocusCard.astro';
import { SITE_VOLUME } from '../consts';

const skills = {
  languages: ['C', 'C++', 'Python', 'TypeScript', 'Go', 'Dart'],
  domains: ['組み込み / IoT', 'Web Frontend', 'クラウドインフラ', 'モバイルアプリ'],
  tools: ['GCP', 'Arduino', 'Astro', 'Flutter', 'Docker', 'GitHub Actions'],
};

const focusAreas = [
  {
    key: 'embedded_iot',
    title: '組み込み・IoT',
    description:
      '物理に触れる回路と、ネットワークの向こうにあるデータ。両者をつなぐ細い導線を設計し、書く仕事に長く関わってきました。',
  },
  {
    key: 'web_frontend',
    title: 'Web フロントエンド',
    description:
      '読み込みの速さ、支援技術での到達しやすさ、コードの型安全性。三方を同時に下げない設計に関心があります。',
  },
  {
    key: 'mobile_app',
    title: 'モバイルアプリ',
    description:
      '単一コードベースから iOS / Android の両側に届けるクロスプラットフォーム開発。ネイティブ実装とのブリッジや、近接無線デバイスとの連携も含めて手を動かしてきました。',
  },
  {
    key: 'cloud_infra',
    title: 'クラウド・インフラ',
    description:
      '本番に届けたコードを、夜の間も静かに走らせ続ける仕組み。クラウド、オンプレ、その境界を渡る経路まで、長く担当してきた裏方の領域です。',
  },
];

const strata = [
  { layer: '物理層', note: '回路、センサー、マイコンの上で動く制御コードを書く。最初に長く居た場所。' },
  { layer: '分散層', note: '複数台のマシンが協調する仕組みを組む。CI/CD、監視、運用の自動化を含む。' },
  { layer: '抽象層', note: '言語処理系、データの形、API の設計など、仕組みの上に乗る規約を扱う。' },
  { layer: '表層',   note: '画面とタイポグラフィ、人が触れる面。最近の主な関心の一つ。' },
];
---

<SiteLayout
  title="About"
  description="横浜のソフトウェアエンジニア keroway のプロフィール。組み込みからクラウド、フロントエンドまで横断して手を動かしてきた領域、関心、使ってきた道具についてまとめています。"
  mainClass="about-main"
>
  {/* UnoCSS 動作検証用サンプル（非表示） */}
  <span class="text-red-500 hidden" aria-hidden="true"></span>
  <!-- Masthead -->
  <section class="masthead" aria-labelledby="profile-heading">
    <div class="masthead__copy">
      <p class="kw-eyebrow masthead__eyebrow">colophon · author</p>
      <!-- TODO: 本名を記入 -->
      <h1 id="profile-heading" class="masthead__title">keroway</h1>
      <p class="masthead__sub">software engineer · yokohama</p>
      <p class="masthead__lead no-indent">
        組み込みからクラウド、フロントエンドまで、領域を横断しながら手を動かしてきました。
        プロトタイプの試作から、本番運用の地味な調整まで、どちらの側も好んで書いています。
      </p>
    </div>
    <div class="masthead__monogram">
      <Monogram tag={`Vol. ${SITE_VOLUME} · 著者`} />
    </div>
  </section>

  <!-- Strata of interest -->
  <section class="section" aria-labelledby="strata-heading">
    <SectionHead jp="関心の地層" en="strata of interest" id="strata-heading" />
    <div class="timeline">
      {strata.map((item, i) => {
        const num = (i + 1).toString().padStart(2, '0');
        return (
          <div class="timeline-row">
            <span class="timeline-row__num kw-numeral kw-tabular">{num}</span>
            <div class="timeline-row__body">
              <p class="kw-eyebrow timeline-row__year no-indent">{item.layer}</p>
              <p class="timeline-row__note no-indent">{item.note}</p>
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <!-- Focus areas -->
  <section class="section" aria-labelledby="focus-areas-heading">
    <SectionHead jp="得意分野" en="focus areas" id="focus-areas-heading" />
    <div class="focus-grid">
      {focusAreas.map((area, i) => (
        <FocusCard index={i} key={area.key} title={area.title} description={area.description} />
      ))}
    </div>
  </section>

  <!-- Stack -->
  <section class="section" aria-labelledby="stack-heading">
    <SectionHead jp="スタック" en="stack" id="stack-heading" />
    <div class="stack-groups">
      {Object.entries({ '言語': skills.languages, '領域': skills.domains, 'ツール・インフラ': skills.tools }).map(([label, items]) => (
        <div class="stack-group">
          <h3 class="kw-eyebrow stack-group__label">{label}</h3>
          <ul class="stack-chips" aria-label={label}>
            {items.map((s) => <li><span class="kw-chip">{s}</span></li>)}
          </ul>
        </div>
      ))}
    </div>
  </section>
</SiteLayout>

<style>
  .about-main {
    width: min(900px, 100%);
  }

  /* Masthead */
  .masthead {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--kw-space-12);
    align-items: end;
    margin-bottom: var(--kw-space-20);
    padding-bottom: var(--kw-space-10);
    border-bottom: 1px solid var(--kw-rule);
  }
  .masthead__eyebrow {
    margin-bottom: var(--kw-space-4);
  }
  .masthead__title {
    font-family: var(--kw-font-display);
    font-size: var(--kw-fs-display-xl);
    font-weight: var(--kw-fw-medium);
    line-height: var(--kw-lh-tight);
    letter-spacing: var(--kw-ls-display);
    color: var(--kw-fg-display);
    margin: 0 0 var(--kw-space-2);
  }
  .masthead__sub {
    font-family: var(--kw-font-mono);
    font-size: var(--kw-fs-mono);
    text-transform: uppercase;
    letter-spacing: var(--kw-ls-eyebrow);
    color: var(--kw-fg-link);
    margin: 0 0 var(--kw-space-6);
    text-indent: 0;
  }
  .masthead__lead {
    color: var(--kw-fg-muted);
    font-size: var(--kw-fs-body-lg);
    line-height: var(--kw-lh-prose);
    max-width: 44ch;
    margin: 0;
  }

  /* Sections */
  .section {
    margin-bottom: var(--kw-space-20);
  }

  /* Timeline */
  .timeline {
    display: flex;
    flex-direction: column;
  }
  .timeline-row {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: var(--kw-space-6);
    align-items: baseline;
    padding: var(--kw-space-6) 0;
    border-bottom: 1px solid var(--kw-rule-soft);
  }
  .timeline-row__num {
    font-size: 22px;
  }
  .timeline-row__year {
    margin-bottom: var(--kw-space-1);
    color: var(--kw-accent);
  }
  .timeline-row__note {
    color: var(--kw-fg);
    margin: 0;
  }

  /* Focus grid */
  .focus-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--kw-space-8);
  }

  /* Stack */
  .stack-groups {
    display: grid;
    gap: var(--kw-space-6);
  }
  .stack-group {
    padding: var(--kw-space-5) 0;
    border-bottom: 1px solid var(--kw-rule-soft);
    display: grid;
    gap: var(--kw-space-3);
  }
  .stack-group:last-child {
    border-bottom: 0;
  }
  .stack-group__label {
    margin: 0;
  }
  .stack-chips {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--kw-space-2);
  }

  @media (max-width: 720px) {
    .masthead {
      grid-template-columns: 1fr;
    }
    .masthead__title {
      font-size: var(--kw-fs-display-sm);
    }
    .masthead__monogram {
      display: none;
    }
    .focus-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
