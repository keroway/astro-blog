---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import CommandPalette from '../components/CommandPalette.astro';
import Footer from '../components/Footer.astro';
import StampRally from '../components/StampRally.astro';
import { SITE_VOLUME } from '../consts';

interface Props {
  title: string;
  description: string;
  image?: string;
  mainClass?: string;
  lang?: string;
  locale?: string;
  canonicalUrl?: string;
  leftRail?: string;
  rightRail?: string;
  articleSchema?: Record<string, unknown>;
  breadcrumbSchema?: Record<string, unknown>;
}

const {
  title,
  description,
  image,
  mainClass,
  lang = 'ja',
  locale: localeOverride,
  canonicalUrl,
  leftRail = 'keroway.com · yokohama',
  rightRail = `Vol. ${SITE_VOLUME} · keroway portfolio`,
  articleSchema,
  breadcrumbSchema,
} = Astro.props;
const locale = localeOverride ?? (lang.startsWith('ja') ? 'ja_JP' : lang.startsWith('en') ? 'en_US' : lang.replace('-', '_'));
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead title={title} description={description} image={image} locale={locale} canonicalUrl={canonicalUrl} articleSchema={articleSchema} breadcrumbSchema={breadcrumbSchema} />
    <slot name="head" />
  </head>
  <body>
    <div class="kw-page">
      <div class="kw-rail" role="presentation" aria-hidden="true">
        <div class="kw-rail__text">{leftRail}</div>
      </div>
      <div class="kw-page__main">
        <Header />
        <main id="main-content" class:list={['site-main', mainClass]} transition:animate="fade" transition:name="site-main">
          <slot />
        </main>
        <Footer />
        <StampRally />
        <CommandPalette />
      </div>
      <div class="kw-rail kw-rail--right" role="presentation" aria-hidden="true">
        <div class="kw-rail__text">{rightRail}</div>
      </div>
    </div>
    <slot name="body-end" />
  </body>
</html>

<script>
  // スクロール連動フェードイン (issue #377)。
  // 初期非表示は html.kw-anim + [data-reveal] (global.css) で表現され、
  // ビューポート進入時に is-visible を付与してフェードインさせる。
  // モーション可否は reduce-motion.ts の prefersReducedMotion() で一元判定。
  import {
    applyMotionPreferences,
    prefersReducedMotion,
    watchReducedMotion,
  } from '../scripts/reduce-motion';

  let observer: IntersectionObserver | null = null;

  function init() {
    applyMotionPreferences();
    const targets = document.querySelectorAll<HTMLElement>('[data-reveal]');
    observer?.disconnect();
    // animation-timeline: view() 対応ブラウザ (issue #499) では global.css の
    // html.kw-scroll-timeline [data-reveal] が CSS だけで reveal を駆動する。
    // ただし view-timeline の "entry" 進捗は初回ロード/reload 時にまだ解決されておらず、
    // 最初から画面内 (above the fold) にある要素が opacity:0 のまま固まる既知の挙動がある
    // (一度もスクロールイベントが発火しないため)。そのため、ロード時点で既にビューポート内に
    // ある要素だけは JS で即座に可視化し、CSS アニメーションは無効化する。fold 外の要素は
    // 従来通り CSS の scroll-timeline に描画を任せる (二重発火を避ける)。
    if (document.documentElement.classList.contains('kw-scroll-timeline')) {
      const vh = window.innerHeight || document.documentElement.clientHeight;
      for (const el of targets) {
        const rect = el.getBoundingClientRect();
        if (rect.top < vh && rect.bottom > 0) el.classList.add('is-visible');
      }
      return;
    }
    // 低減時 / IO 未対応は隠さず即表示 (kw-anim も付いていない)。
    if (prefersReducedMotion() || !('IntersectionObserver' in window)) {
      for (const el of targets) el.classList.add('is-visible');
      return;
    }
    observer = new IntersectionObserver(
      (entries, obs) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          entry.target.classList.add('is-visible');
          obs.unobserve(entry.target);
        }
      },
      { rootMargin: '0px 0px -10% 0px', threshold: 0.05 }
    );
    for (const el of targets) {
      if (el.classList.contains('is-visible')) continue;
      observer.observe(el);
    }
  }

  // 初回ロードと View Transitions (ClientRouter) の遷移後の両方で発火する。
  document.addEventListener('astro:page-load', init);
  watchReducedMotion(() => init());
</script>

<style>
  .kw-page {
    display: grid;
    grid-template-columns: var(--kw-rail-width) 1fr var(--kw-rail-width);
    min-height: 100vh;
    max-width: 1400px;
    margin: 0 auto;
  }
  .kw-page__main {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .site-main {
    flex: 1;
    width: min(var(--kw-content-max), 100%);
    margin: 0 auto;
    padding: var(--kw-space-16) var(--kw-space-8) var(--kw-space-20);
  }
  @media (max-width: 900px) {
    .kw-page {
      grid-template-columns: 1fr;
    }
    :global(.kw-rail) {
      display: none;
    }
  }
  @media (max-width: 720px) {
    .site-main {
      padding: var(--kw-space-8) var(--kw-space-4) var(--kw-space-12);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .site-main {
      transition-duration: 0.01ms !important;
      transition-delay: 0ms !important;
    }
  }
</style>
