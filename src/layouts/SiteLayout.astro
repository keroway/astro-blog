---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_VOLUME } from '../consts';

interface Props {
  title: string;
  description: string;
  image?: string;
  mainClass?: string;
  lang?: string;
  locale?: string;
  canonicalUrl?: string;
  leftRail?: string;
  rightRail?: string;
  articleSchema?: Record<string, unknown>;
}

const {
  title,
  description,
  image,
  mainClass,
  lang = 'ja',
  locale: localeOverride,
  canonicalUrl,
  leftRail = 'keroway.com · yokohama',
  rightRail = `Vol. ${SITE_VOLUME} · keroway portfolio`,
  articleSchema,
} = Astro.props;
const locale = localeOverride ?? (lang.startsWith('ja') ? 'ja_JP' : lang.startsWith('en') ? 'en_US' : lang.replace('-', '_'));
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead title={title} description={description} image={image} locale={locale} canonicalUrl={canonicalUrl} articleSchema={articleSchema} />
    <slot name="head" />
  </head>
  <body>
    <div class="kw-page">
      <div class="kw-rail" role="presentation" aria-hidden="true">
        <div class="kw-rail__text">{leftRail}</div>
      </div>
      <div class="kw-page__main">
        <Header />
        <main class:list={['site-main', mainClass]} transition:animate="fade" transition:name="site-main">
          <slot />
        </main>
        <Footer />
      </div>
      <div class="kw-rail kw-rail--right" role="presentation" aria-hidden="true">
        <div class="kw-rail__text">{rightRail}</div>
      </div>
    </div>
    <slot name="body-end" />
  </body>
</html>

<style>
  .kw-page {
    display: grid;
    grid-template-columns: var(--kw-rail-width) 1fr var(--kw-rail-width);
    min-height: 100vh;
    max-width: 1400px;
    margin: 0 auto;
  }
  .kw-page__main {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .site-main {
    flex: 1;
    width: min(var(--kw-content-max), 100%);
    margin: 0 auto;
    padding: var(--kw-space-16) var(--kw-space-8) var(--kw-space-20);
  }
  @media (max-width: 900px) {
    .kw-page {
      grid-template-columns: 1fr;
    }
    :global(.kw-rail) {
      display: none;
    }
  }
  @media (max-width: 720px) {
    .site-main {
      padding: var(--kw-space-8) var(--kw-space-4) var(--kw-space-12);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .site-main {
      transition-duration: 0.01ms !important;
      transition-delay: 0ms !important;
    }
  }
</style>
