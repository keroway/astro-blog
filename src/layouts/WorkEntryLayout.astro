---
import type { CollectionEntry } from "astro:content";
import SiteLayout from "./SiteLayout.astro";

type Props = CollectionEntry<"works">["data"];

const work = Astro.props as Props;
const { title, description, heroImage, status, tags, createdAt, updatedAt, repoUrl, lpUrl, demoUrl } = work;

const statusMap = {
	active: { label: "Active", className: "is-active", note: "現在も公開・更新中のプロジェクト" },
	wip: { label: "WIP", className: "is-wip", note: "検証と改善を進めている開発中のプロジェクト" },
	archived: { label: "Archived", className: "is-archived", note: "公開は継続しつつ更新は落ち着いたプロジェクト" },
} as const;

const statusMeta = statusMap[status];
---

<SiteLayout
	title={`${title} | Works`}
	description={description}
	image={heroImage ?? "/blog-placeholder-100.png"}
	mainClass="work-layout"
>
	<article class="work-entry">
		<header class="work-hero">
			<div class="work-hero__intro">
				<p class="work-hero__eyebrow">Works / Tool Profile</p>
				<div class="work-hero__meta">
					<span class:list={["work-status", statusMeta.className]}>{statusMeta.label}</span>
					<span>{statusMeta.note}</span>
				</div>
				<h1>{title}</h1>
				<p class="work-hero__lead">{description}</p>
				<div class="work-hero__actions">
					<a class="button" href={lpUrl} target="_blank" rel="noopener noreferrer">LP を開く</a>
					<a class="button button--ghost" href={repoUrl} target="_blank" rel="noopener noreferrer">Repository</a>
					{demoUrl && (
						<a class="button button--ghost" href={demoUrl} target="_blank" rel="noopener noreferrer">Demo</a>
					)}
				</div>
			</div>
			<aside class="work-facts" aria-label="project facts">
				<div>
					<dt>Started</dt>
					<dd>{createdAt.toLocaleDateString("ja-JP")}</dd>
				</div>
				{updatedAt && (
					<div>
						<dt>Updated</dt>
						<dd>{updatedAt.toLocaleDateString("ja-JP")}</dd>
					</div>
				)}
				<div>
					<dt>Stack</dt>
					<dd>
						<ul class="work-facts__tags">
							{tags.map((tag) => (
								<li>{tag}</li>
							))}
						</ul>
					</dd>
				</div>
			</aside>
		</header>
		{
			heroImage && (
				<figure class="work-entry__hero">
					<img src={heroImage} alt="" loading="lazy" />
				</figure>
			)
		}
		<div class="work-entry__content">
			<slot />
		</div>
		<section class="work-cta" aria-labelledby="work-cta-heading">
			<div class="work-cta__copy">
				<p class="work-cta__eyebrow">External Links</p>
				<h2 id="work-cta-heading">プロダクト本体や LP に移動</h2>
				<p>このページでは背景と設計判断をまとめ、詳細な導線は外部 LP / リポジトリ側に集約しています。</p>
			</div>
			<div class="work-cta__actions">
				<a class="button" href={lpUrl} target="_blank" rel="noopener noreferrer">LP を見る</a>
				<a class="button button--ghost" href={repoUrl} target="_blank" rel="noopener noreferrer">GitHub</a>
				{demoUrl && (
					<a class="button button--ghost" href={demoUrl} target="_blank" rel="noopener noreferrer">Demo</a>
				)}
			</div>
		</section>
	</article>
</SiteLayout>

<style>
	.work-layout {
		width: min(88rem, 100%);
		padding-block-start: clamp(2rem, 5vw, 3.5rem);
	}
	.work-entry {
		display: grid;
		gap: clamp(2rem, 4vw, 3rem);
	}
	.work-hero {
		display: grid;
		grid-template-columns: minmax(0, 1.7fr) minmax(280px, 0.9fr);
		gap: clamp(1.25rem, 3vw, 2rem);
		align-items: start;
	}
	.work-hero__intro,
	.work-facts,
	.work-cta {
		background: var(--surface);
		border: 1px solid rgba(var(--gray), 0.12);
		box-shadow: var(--shadow-md);
		border-radius: 24px;
	}
	.work-hero__intro {
		padding: clamp(1.75rem, 4vw, 3rem);
		background:
			radial-gradient(circle at top right, rgba(59, 130, 246, 0.16), transparent 32%),
			linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(248, 250, 252, 0.98));
	}
	.work-hero__eyebrow,
	.work-cta__eyebrow {
		margin: 0 0 0.75rem;
		font-size: 0.85rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: rgba(var(--gray), 0.75);
	}
	.work-hero__meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.75rem;
		font-size: 0.95rem;
		color: var(--text-muted);
	}
	.work-status {
		display: inline-flex;
		align-items: center;
		padding: 0.4rem 0.8rem;
		border-radius: 999px;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}
	.work-status.is-active {
		background: rgba(22, 163, 74, 0.12);
		color: #166534;
	}
	.work-status.is-wip {
		background: rgba(217, 119, 6, 0.14);
		color: #9a3412;
	}
	.work-status.is-archived {
		background: rgba(var(--gray), 0.1);
		color: rgb(var(--gray-dark));
	}
	.work-hero h1 {
		margin: 1rem 0 0.75rem;
		font-size: clamp(2.2rem, 5vw, 3.4rem);
		line-height: 1.05;
	}
	.work-hero__lead {
		margin: 0;
		font-size: 1.05rem;
		color: rgb(var(--gray-dark));
		max-width: 58ch;
	}
	.work-hero__actions,
	.work-cta__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.85rem;
		margin-top: 1.5rem;
	}
	.work-facts {
		padding: clamp(1.4rem, 3vw, 2rem);
		display: grid;
		gap: 1.25rem;
	}
	.work-facts div {
		display: grid;
		gap: 0.35rem;
	}
	.work-facts dt {
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: rgba(var(--gray), 0.75);
	}
	.work-facts dd {
		margin: 0;
		color: rgb(var(--gray-dark));
	}
	.work-facts__tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.55rem;
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.work-facts__tags li {
		padding: 0.35rem 0.7rem;
		border-radius: 999px;
		background: rgba(var(--gray-light), 0.8);
		border: 1px solid rgba(var(--gray), 0.12);
		font-size: 0.8rem;
	}
	.work-entry__hero {
		margin: 0;
		background: var(--surface);
		border: 1px solid rgba(var(--gray), 0.12);
		border-radius: 24px;
		overflow: clip;
		box-shadow: var(--shadow-sm);
	}
	.work-entry__hero img {
		display: block;
		width: 100%;
	}
	.work-entry__content {
		background: rgba(255, 255, 255, 0.72);
		border: 1px solid rgba(var(--gray), 0.08);
		border-radius: 24px;
		padding: clamp(1.5rem, 4vw, 2.6rem);
		box-shadow: var(--shadow-sm);
	}
	.work-entry__content :global(:where(* + *)) {
		margin-block-start: clamp(1.25rem, 3vw, 2rem);
	}
	.work-entry__content :global(h2) {
		font-size: clamp(1.5rem, 3vw, 2rem);
	}
	.work-entry__content :global(p) {
		margin: 0;
	}
	.work-cta {
		padding: clamp(1.6rem, 3.5vw, 2.4rem);
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 1rem 2rem;
		align-items: center;
	}
	.work-cta h2,
	.work-cta p {
		margin: 0;
	}
	.work-cta p {
		color: var(--text-muted);
	}
	@media (max-width: 900px) {
		.work-hero,
		.work-cta {
			grid-template-columns: 1fr;
		}
	}
	@media (max-width: 640px) {
		.work-hero__intro,
		.work-facts,
		.work-entry__content,
		.work-cta {
			border-radius: 20px;
		}
	}
</style>
