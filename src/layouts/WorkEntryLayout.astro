---
import type { CollectionEntry } from "astro:content";
import SiteLayout from "./SiteLayout.astro";

type Props = CollectionEntry<"works">["data"];

const work = Astro.props as Props;
const { title, description, heroImage, status, tags, createdAt, updatedAt, repoUrl, lpUrl, demoUrl } = work;

const statusMap = {
  active:   { label: "Active",   className: "kw-chip--status-active",   note: "現在も公開・更新中のプロジェクト" },
  wip:      { label: "WIP",      className: "kw-chip--status-wip",      note: "検証と改善を進めている開発中のプロジェクト" },
  archived: { label: "Archived", className: "kw-chip--status-archived", note: "公開は継続しつつ更新は落ち着いたプロジェクト" },
} as const;

const statusMeta = statusMap[status];
---

<SiteLayout
  title={`${title} | Works`}
  description={description}
  image={heroImage ?? "/blog-placeholder-100.png"}
  mainClass="work-layout"
>
  <article class="work-entry">
    <header class="work-hero">
      <div class="work-hero__intro">
        <p class="kw-eyebrow work-hero__eyebrow">Works / Tool Profile</p>
        <div class="work-hero__meta">
          <span class:list={["kw-chip", statusMeta.className]}>{statusMeta.label}</span>
          <span class="kw-mono work-hero__meta-note">{statusMeta.note}</span>
        </div>
        <h1 class="work-hero__title">{title}</h1>
        <p class="work-hero__lead no-indent">{description}</p>
        <div class="work-hero__actions">
          <a class="kw-button" href={lpUrl} target="_blank" rel="noopener noreferrer">LP を開く <span class="kw-button-arrow">→</span></a>
          <a class="kw-button kw-button--ghost" href={repoUrl} target="_blank" rel="noopener noreferrer">Repository</a>
          {demoUrl && (
            <a class="kw-button kw-button--ghost" href={demoUrl} target="_blank" rel="noopener noreferrer">Demo</a>
          )}
        </div>
      </div>
      <aside class="work-facts" aria-label="project facts">
        <div class="work-facts__row">
          <dt class="kw-eyebrow">Started</dt>
          <dd class="kw-mono">{createdAt.toLocaleDateString("ja-JP")}</dd>
        </div>
        {updatedAt && (
          <div class="work-facts__row">
            <dt class="kw-eyebrow">Updated</dt>
            <dd class="kw-mono">{updatedAt.toLocaleDateString("ja-JP")}</dd>
          </div>
        )}
        <div class="work-facts__row">
          <dt class="kw-eyebrow">Stack</dt>
          <dd>
            <ul class="work-facts__tags">
              {tags.map((tag) => (
                <li><span class="kw-chip">{tag}</span></li>
              ))}
            </ul>
          </dd>
        </div>
      </aside>
    </header>

    {heroImage && (
      <figure class="work-entry__hero">
        <img src={heroImage} alt="" loading="lazy" />
      </figure>
    )}

    <div class="work-entry__content">
      <slot />
    </div>

    <section class="work-cta" aria-labelledby="work-cta-heading">
      <div class="work-cta__copy">
        <p class="kw-eyebrow work-cta__eyebrow">External Links</p>
        <h2 id="work-cta-heading" class="work-cta__heading">プロダクト本体や LP に移動</h2>
        <p class="no-indent">このページでは背景と設計判断をまとめ、詳細な導線は外部 LP / リポジトリ側に集約しています。</p>
      </div>
      <div class="work-cta__actions">
        <a class="kw-button" href={lpUrl} target="_blank" rel="noopener noreferrer">LP を見る <span class="kw-button-arrow">→</span></a>
        <a class="kw-button kw-button--ghost" href={repoUrl} target="_blank" rel="noopener noreferrer">GitHub</a>
        {demoUrl && (
          <a class="kw-button kw-button--ghost" href={demoUrl} target="_blank" rel="noopener noreferrer">Demo</a>
        )}
      </div>
    </section>
  </article>
</SiteLayout>

<style>
  .work-layout {
    width: min(var(--kw-content-max), 100%);
    padding-block-start: var(--kw-space-12);
  }
  .work-entry {
    display: grid;
    gap: var(--kw-space-10);
  }

  /* Hero */
  .work-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.7fr) minmax(240px, 0.8fr);
    gap: var(--kw-space-6);
    align-items: start;
  }

  .work-hero__intro,
  .work-facts,
  .work-cta {
    background: var(--kw-bg-card);
    border: 1px solid var(--kw-rule);
    border-radius: var(--kw-radius-md);
  }
  .work-hero__intro {
    padding: var(--kw-space-8);
  }
  .work-hero__eyebrow {
    margin-bottom: var(--kw-space-4);
  }
  .work-hero__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--kw-space-3);
    margin-bottom: var(--kw-space-5);
  }
  .work-hero__meta-note {
    font-size: var(--kw-fs-mono-sm);
    color: var(--kw-fg-muted);
  }
  .work-hero__title {
    font-family: var(--kw-font-display);
    font-size: clamp(var(--kw-fs-display-sm), 5vw, var(--kw-fs-display-md));
    font-weight: var(--kw-fw-medium);
    line-height: var(--kw-lh-snug);
    letter-spacing: var(--kw-ls-display);
    color: var(--kw-fg-display);
    margin: 0 0 var(--kw-space-5);
  }
  .work-hero__lead {
    color: var(--kw-fg-muted);
    font-size: var(--kw-fs-body-lg);
    max-width: 50ch;
    line-height: var(--kw-lh-prose);
    margin: 0 0 var(--kw-space-6);
  }
  .work-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--kw-space-4);
  }

  /* Facts sidebar */
  .work-facts {
    padding: var(--kw-space-6);
    display: grid;
    gap: var(--kw-space-5);
  }
  .work-facts__row {
    display: grid;
    gap: var(--kw-space-2);
  }
  .work-facts__row dt {
    margin-bottom: 2px;
  }
  .work-facts__row dd {
    margin: 0;
    color: var(--kw-fg);
    font-size: var(--kw-fs-mono-sm);
  }
  .work-facts__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--kw-space-2);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  /* Hero image */
  .work-entry__hero {
    margin: 0;
    background: var(--kw-bg-card);
    border: 1px solid var(--kw-rule);
    border-radius: var(--kw-radius-md);
    overflow: clip;
  }
  .work-entry__hero img {
    display: block;
    width: 100%;
  }

  /* Content */
  .work-entry__content {
    background: var(--kw-bg-card);
    border: 1px solid var(--kw-rule);
    border-radius: var(--kw-radius-md);
    padding: var(--kw-space-8);
  }
  .work-entry__content :global(:where(* + *)) {
    margin-block-start: clamp(var(--kw-space-5), 3vw, var(--kw-space-8));
  }
  .work-entry__content :global(h2) {
    font-size: var(--kw-fs-h2);
  }
  .work-entry__content :global(p) {
    margin: 0;
  }

  /* CTA */
  .work-cta {
    padding: var(--kw-space-8);
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: var(--kw-space-6) var(--kw-space-10);
    align-items: center;
  }
  .work-cta__eyebrow {
    margin-bottom: var(--kw-space-2);
  }
  .work-cta__heading {
    font-size: var(--kw-fs-h3);
    margin: 0 0 var(--kw-space-2);
  }
  .work-cta p {
    color: var(--kw-fg-muted);
    margin: 0;
    font-size: var(--kw-fs-body-sm);
  }
  .work-cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--kw-space-4);
  }

  @media (max-width: 900px) {
    .work-hero,
    .work-cta {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 640px) {
    .work-hero__intro,
    .work-facts,
    .work-entry__content,
    .work-cta {
      padding: var(--kw-space-5);
    }
  }
</style>
