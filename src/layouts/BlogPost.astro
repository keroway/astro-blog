---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import SiteLayout from "./SiteLayout.astro";
import FormattedDate from "../components/FormattedDate.astro";

type Props = CollectionEntry<"blog">["data"];

const post = Astro.props as Props;
const { title, description, pubDate, updatedDate, heroImage } = post;
---

<SiteLayout title={title} description={description} image={heroImage} mainClass="post-layout">
	<article class="post">
		{
			heroImage && (
				<figure class="post__hero">
					<Image src={heroImage} alt="" width={1200} height={630} transition:name={`hero-${title}`} />
				</figure>
			)
		}
		<header class="post__header">
			<div class="post__meta">
				<time datetime={pubDate.toISOString()}>
					<FormattedDate date={pubDate} />
				</time>
				{
					updatedDate && (
						<span class="post__meta-update">
							最終更新 <FormattedDate date={updatedDate} />
						</span>
					)
				}
			</div>
			<h1>{title}</h1>
			<hr />
		</header>
		<div class="post__content">
			<slot />
		</div>
	</article>
</SiteLayout>

<style>
	.post-layout {
		width: min(76ch, 100%);
		padding-block-start: clamp(2.5rem, 6vw, 4rem);
	}
	.post {
		display: grid;
		gap: clamp(1.5rem, 4vw, 2.5rem);
	}
	.post__hero {
		margin: 0;
		border-radius: 18px;
		overflow: clip;
		box-shadow: var(--box-shadow);
	}
	.post__hero img {
		display: block;
		width: 100%;
		height: auto;
		object-fit: cover;
	}
	.post__header {
		text-align: center;
		display: grid;
		gap: 0.75rem;
		color: rgb(var(--gray-dark));
	}
	.post__header h1 {
		margin: 0;
		font-size: clamp(2.2rem, 4vw, 2.8rem);
	}
	.post__meta {
		display: flex;
		justify-content: center;
		gap: 1rem;
		color: rgb(var(--gray));
		font-size: 0.95rem;
		flex-wrap: wrap;
	}
	.post__meta-update {
		font-style: italic;
	}
	.post__content {
		color: rgb(var(--gray-dark));
	}
	.post__content :global(img) {
		width: 100%;
		height: auto;
	}
	.post__content :global(:where(* + *)) {
		margin-block-start: clamp(1.5rem, 3vw, 2.25rem);
	}
	@media (max-width: 720px) {
		.post-layout {
			padding-block-start: 2rem;
		}
	}
</style>
