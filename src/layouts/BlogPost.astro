---
import { getImage } from "astro:assets";
import SiteLayout from "./SiteLayout.astro";
import ContentPicture from "../components/ContentPicture.astro";
import FormattedDate from "../components/FormattedDate.astro";
import TableOfContents from "../components/TableOfContents.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import ReadingProgress from "../components/ReadingProgress.astro";
import PostShare from "../components/PostShare.astro";
import PostSeriesNav from "../components/PostSeriesNav.astro";
import PostNav from "../components/PostNav.astro";
import PostRelated from "../components/PostRelated.astro";
import { SITE_AUTHOR } from "../consts";
import type { BlogData, BlogEntry } from "../types/content";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props extends BlogData {
  ogImage?: string;
  readingTime?: number;
  headings?: Heading[];
  prevPost?: BlogEntry | null;
  nextPost?: BlogEntry | null;
  relatedPosts?: BlogEntry[];
  seriesNav?: {
    name: string;
    current: number;
    total: number;
    prev: BlogEntry | null;
    next: BlogEntry | null;
  } | null;
  tags?: string[];
}

const post = Astro.props as Props;
const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  canonicalUrl,
  ogImage,
  author,
  readingTime,
  headings = [],
  prevPost = null,
  nextPost = null,
  relatedPosts = [],
  seriesNav = null,
  tags = [],
} = post;
const heroImageSrc = heroImage
  ? heroImage.format === "svg"
    ? heroImage.src
    : (await getImage({ src: heroImage, width: 1200, format: "png" })).src
  : undefined;
const tocItems = headings.filter((h) => h.depth === 2 || h.depth === 3);

const shareUrl = Astro.url.href;

const postUrl = canonicalUrl ?? new URL(Astro.url.pathname, Astro.site).toString();
const heroImageAbsolute = heroImageSrc
  ? (Astro.site ? new URL(heroImageSrc, Astro.site).toString() : heroImageSrc)
  : undefined;
const articleSchema: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  author: {
    "@type": "Person",
    name: author ?? SITE_AUTHOR,
  },
  url: postUrl,
  mainEntityOfPage: postUrl,
};
if (updatedDate) {
  articleSchema.dateModified = updatedDate.toISOString();
}
if (heroImageAbsolute) {
  articleSchema.image = heroImageAbsolute;
}

const siteUrl = Astro.site ? new URL("/", Astro.site).toString() : `${Astro.url.origin}/`;
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
    { "@type": "ListItem", position: 2, name: "Blog", item: new URL("/blog/", siteUrl).toString() },
    { "@type": "ListItem", position: 3, name: title, item: postUrl },
  ],
};
---

<SiteLayout title={title} description={description} image={ogImage ?? heroImageSrc} mainClass="post-layout" canonicalUrl={canonicalUrl} articleSchema={articleSchema} breadcrumbSchema={breadcrumbSchema}>
  <ReadingProgress />
  <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "Blog", href: "/blog/" }, { label: title }]} />
  <div class="post-wrap">
    <article class="post">
      {heroImage && (
        <figure class="post__hero">
          {/* hero は LCP 候補。eager + fetchpriority="high" で優先読み込みする (#396) */}
          <ContentPicture
            src={heroImage}
            alt={title}
            widths={[640, 960, 1280, 1600]}
            sizes="(min-width: 901px) 76ch, 100vw"
            loading="eager"
            fetchpriority="high"
            decoding="async"
            transition:name={`hero-${title}`}
          />
        </figure>
      )}
      <header class="post__header">
        <div class="post__meta">
          <time class="kw-mono post__meta-date" datetime={pubDate.toISOString()}>
            <FormattedDate date={pubDate} />
          </time>
          {updatedDate && (
            <span class="kw-mono post__meta-update">
              最終更新 <FormattedDate date={updatedDate} />
            </span>
          )}
          {readingTime !== undefined && (
            <span class="kw-mono post__meta-reading" aria-label={`読了時間 約 ${readingTime} 分`}>
              約 {readingTime} 分
            </span>
          )}
        </div>
        <h1 class="post__title" data-pagefind-meta="title">{title}</h1>
        <hr />
        {tags.length > 0 && (
          <ul class="post__tags" aria-label="タグ">
            {tags.map((tag) => (
              <li>
                <a href={`/blog/tags/${encodeURIComponent(tag)}/`} class="post__tag">#{tag}</a>
              </li>
            ))}
          </ul>
        )}
      </header>
      {tocItems.length > 0 && (
        <div class="toc-mobile">
          <TableOfContents headings={headings} />
        </div>
      )}
      <div class="post__content" data-pagefind-body id="post-content">
        <slot />
      </div>

      <PostShare title={title} url={shareUrl} />

      <PostSeriesNav seriesNav={seriesNav} />

      <PostNav prevPost={prevPost} nextPost={nextPost} />

      <PostRelated posts={relatedPosts} />
    </article>
    {tocItems.length > 0 && (
      <aside class="toc-sidebar" aria-label="目次">
        <TableOfContents headings={headings} />
      </aside>
    )}
  </div>
</SiteLayout>

<script>
  // 見出しに permalink アンカーリンクを付与する (issue #446)。
  // rehype-slug 等を導入せず、既存の headings (id 付与済み) を利用したプログレッシブエンハンスメント。
  const addHeadingAnchors = () => {
    const content = document.getElementById('post-content');
    if (!content) return;
    const headings = content.querySelectorAll<HTMLHeadingElement>('h2[id], h3[id], h4[id]');
    headings.forEach((heading) => {
      if (heading.querySelector('.heading-anchor')) return;
      const anchor = document.createElement('a');
      anchor.className = 'heading-anchor';
      anchor.href = `#${heading.id}`;
      anchor.setAttribute('aria-label', `「${heading.textContent ?? ''}」への直接リンク`);
      anchor.textContent = '#';
      heading.appendChild(anchor);
    });
  };

  addHeadingAnchors();
  document.addEventListener('astro:page-load', addHeadingAnchors);

  // コードブロックにコピーボタンを付与する (issue #448)。JS 無効時はボタンは何も表示しないプログレッシブエンハンスメント。
  const addCodeCopyButtons = () => {
    const content = document.getElementById('post-content');
    if (!content) return;
    const blocks = content.querySelectorAll<HTMLPreElement>('pre');
    blocks.forEach((pre) => {
      if (pre.parentElement?.classList.contains('code-block')) return;
      const code = pre.querySelector('code');
      if (!code) return;

      const wrapper = document.createElement('div');
      wrapper.className = 'code-block';
      pre.replaceWith(wrapper);
      wrapper.appendChild(pre);

      const button = document.createElement('button');
      button.type = 'button';
      button.className = 'code-block__copy';
      button.setAttribute('aria-label', 'コードをコピー');
      button.textContent = 'Copy';

      const status = document.createElement('span');
      status.className = 'code-block__status';
      status.setAttribute('aria-live', 'polite');
      status.setAttribute('role', 'status');

      button.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(code.textContent ?? '');
        } catch {
          return;
        }
        button.textContent = 'Copied';
        status.textContent = 'コードをコピーしました';
        button.disabled = true;
        window.setTimeout(() => {
          button.textContent = 'Copy';
          status.textContent = '';
          button.disabled = false;
        }, 1500);
      });

      wrapper.appendChild(button);
      wrapper.appendChild(status);
    });
  };

  addCodeCopyButtons();
  document.addEventListener('astro:page-load', addCodeCopyButtons);
</script>

<style>
  .post-layout {
    width: min(76ch, 100%);
    padding-block-start: var(--kw-space-12);
  }
  .post-wrap {
    display: contents;
  }
  .post {
    display: grid;
    gap: var(--kw-space-8);
  }
  .toc-mobile { display: block; }
  .toc-sidebar { display: none; }

  .post__hero {
    margin: 0;
    border-radius: var(--kw-radius-md);
    overflow: clip;
    border: 1px solid var(--kw-rule);
    display: flex;
    justify-content: center;
    align-items: center;
    background: var(--kw-bg-card);
  }
  .post__hero img {
    display: block;
    max-width: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  .post__header {
    text-align: start;
    display: grid;
    gap: var(--kw-space-4);
  }
  .post__meta {
    display: flex;
    gap: var(--kw-space-4);
    flex-wrap: wrap;
    font-size: var(--kw-fs-mono-sm);
    color: var(--kw-fg-muted);
  }
  .post__meta-date,
  .post__meta-update,
  .post__meta-reading {
    font-family: var(--kw-font-mono);
  }
  .post__meta-update { font-style: italic; }

  .post__tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--kw-space-2);
    padding: 0;
    margin: 0;
  }
  .post__tag {
    font-family: var(--kw-font-mono);
    font-size: var(--kw-fs-mono-xs);
    color: var(--kw-fg-muted);
    text-decoration: none;
    border: 1px solid var(--kw-rule-soft);
    border-radius: var(--kw-radius-sm);
    padding: var(--kw-space-1) var(--kw-space-3);
    transition: border-color var(--kw-duration-fast) var(--kw-easing),
                color var(--kw-duration-fast) var(--kw-easing);
  }
  .post__tag:hover {
    border-color: var(--kw-accent);
    color: var(--kw-accent);
  }

  .post__title {
    font-family: var(--kw-font-display);
    font-size: clamp(var(--kw-fs-display-sm), 4vw, var(--kw-fs-display-md));
    font-weight: var(--kw-fw-medium);
    letter-spacing: var(--kw-ls-display);
    line-height: var(--kw-lh-snug);
    color: var(--kw-fg-display);
    margin: 0;
  }

  .post__content {
    color: var(--kw-fg);
    overflow-wrap: break-word;
    word-wrap: break-word;
    line-height: var(--kw-lh-prose);
  }
  .post__content :global(img) {
    max-width: 100%;
    width: auto;
    height: auto;
    display: block;
    margin-inline: auto;
  }
  .post__content :global(pre) {
    overflow-x: auto;
    max-width: 100%;
  }
  .post__content :global(.code-block) {
    position: relative;
  }
  .post__content :global(.code-block__copy) {
    position: absolute;
    top: var(--kw-space-2);
    right: var(--kw-space-2);
    font-family: var(--kw-font-mono);
    font-size: var(--kw-fs-mono-xs);
    color: var(--kw-fg-muted);
    background: var(--kw-bg-card);
    border: 1px solid var(--kw-rule);
    border-radius: var(--kw-radius-sm);
    padding: var(--kw-space-1) var(--kw-space-3);
    cursor: pointer;
    opacity: 0;
    transition: opacity var(--kw-duration-fast) var(--kw-easing),
      border-color var(--kw-duration-fast) var(--kw-easing),
      color var(--kw-duration-fast) var(--kw-easing);
  }
  .post__content :global(.code-block:hover .code-block__copy),
  .post__content :global(.code-block__copy:focus-visible) {
    opacity: 1;
  }
  .post__content :global(.code-block__copy:hover) {
    border-color: var(--kw-fg-link);
    color: var(--kw-fg-link);
  }
  .post__content :global(.code-block__copy:focus-visible) {
    outline: 2px solid var(--kw-blue);
    outline-offset: 2px;
  }
  .post__content :global(.code-block__copy:disabled) {
    cursor: default;
  }
  .post__content :global(.code-block__status) {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
  }
  @media (max-width: 720px) {
    .post__content :global(.code-block__copy) {
      opacity: 1;
    }
  }
  .post__content :global(table) {
    display: block;
    overflow-x: auto;
    max-width: 100%;
  }
  .post__content :global(:where(* + *)) {
    margin-block-start: clamp(var(--kw-space-6), 3vw, var(--kw-space-10));
  }
  .post__content :global(h2),
  .post__content :global(h3),
  .post__content :global(h4) {
    position: relative;
  }
  .post__content :global(.heading-anchor) {
    position: absolute;
    inset-inline-start: -1.2em;
    color: var(--kw-fg-muted);
    text-decoration: none;
    font-family: var(--kw-font-mono);
    opacity: 0;
    transition: opacity var(--kw-duration-fast) var(--kw-easing);
  }
  .post__content :global(h2:hover .heading-anchor),
  .post__content :global(h3:hover .heading-anchor),
  .post__content :global(h4:hover .heading-anchor),
  .post__content :global(.heading-anchor:focus-visible) {
    opacity: 1;
  }
  .post__content :global(.heading-anchor:focus-visible) {
    outline: 2px solid var(--kw-blue);
    outline-offset: 2px;
  }
  @media (max-width: 720px) {
    .post__content :global(.heading-anchor) {
      position: static;
      display: inline-block;
      margin-inline-start: var(--kw-space-2);
      opacity: 1;
    }
  }

  @media (min-width: 901px) {
    :global(.post-layout) {
      width: min(100%, 112ch);
    }
    .post-wrap {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 15rem;
      gap: clamp(var(--kw-space-8), 4vw, var(--kw-space-12));
      align-items: start;
    }
    .post {
      grid-column: 1;
      grid-row: 1;
    }
    .toc-mobile { display: none; }
    .toc-sidebar {
      display: block;
      grid-column: 2;
      grid-row: 1;
      position: sticky;
      top: clamp(var(--kw-space-6), 3vw, var(--kw-space-8));
      max-height: calc(100vh - 5rem);
      overflow-y: auto;
    }
  }

  @media (max-width: 720px) {
    .post-layout {
      padding-block-start: var(--kw-space-8);
    }
  }
</style>
