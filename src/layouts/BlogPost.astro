---
import type { CollectionEntry } from "astro:content";
import SiteLayout from "./SiteLayout.astro";
import FormattedDate from "../components/FormattedDate.astro";
import TableOfContents from "../components/TableOfContents.astro";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

type BlogData = CollectionEntry<"blog">["data"];
type BlogEntry = CollectionEntry<"blog">;

interface Props extends BlogData {
  headings?: Heading[];
  prevPost?: BlogEntry | null;
  nextPost?: BlogEntry | null;
  relatedPosts?: BlogEntry[];
}

const post = Astro.props as Props;
const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  canonicalUrl,
  headings = [],
  prevPost = null,
  nextPost = null,
  relatedPosts = [],
} = post;
const heroImageSrc = heroImage ?? '/blog-placeholder-100.png';
const tocItems = headings.filter((h) => h.depth === 2 || h.depth === 3);

const encodeSlug = (id: string) =>
  id.split('/').map((segment) => encodeURIComponent(segment)).join('/');
const postHref = (entry: BlogEntry) => `/blog/${encodeSlug(entry.id)}/`;

const shareUrl = Astro.url.href;
const xIntent = `https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(shareUrl)}`;
---

<SiteLayout title={title} description={description} image={heroImageSrc} mainClass="post-layout" canonicalUrl={canonicalUrl}>
  <div class="post-wrap">
    <article class="post">
      {heroImage && (
        <figure class="post__hero">
          <img src={heroImage} alt="" loading="lazy" transition:name={`hero-${title}`} />
        </figure>
      )}
      <header class="post__header">
        <div class="post__meta">
          <time class="kw-mono post__meta-date" datetime={pubDate.toISOString()}>
            <FormattedDate date={pubDate} />
          </time>
          {updatedDate && (
            <span class="kw-mono post__meta-update">
              最終更新 <FormattedDate date={updatedDate} />
            </span>
          )}
        </div>
        <h1 class="post__title">{title}</h1>
        <hr />
      </header>
      {tocItems.length > 0 && (
        <div class="toc-mobile">
          <TableOfContents headings={headings} />
        </div>
      )}
      <div class="post__content">
        <slot />
      </div>

      <section class="post-share" aria-label="この記事をシェア">
        <p class="kw-eyebrow post-share__label no-indent">share</p>
        <div class="post-share__actions">
          <a
            class="post-share__btn"
            href={xIntent}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="X で共有"
          >
            <span class="post-share__btn-arrow" aria-hidden="true">→</span>
            X で共有
          </a>
          <button
            type="button"
            class="post-share__btn post-share__copy"
            data-share-url={shareUrl}
            data-copy-label="URL をコピー"
            data-copied-label="コピーしました"
          >
            <span class="post-share__btn-arrow" aria-hidden="true">→</span>
            <span class="post-share__copy-text">URL をコピー</span>
          </button>
        </div>
      </section>

      {(prevPost || nextPost) && (
        <nav class="post-nav" aria-label="前後の記事">
          {prevPost ? (
            <a class="post-nav__item post-nav__item--prev" href={postHref(prevPost)}>
              <span class="kw-eyebrow post-nav__dir no-indent">← 前の記事</span>
              <span class="post-nav__title">{prevPost.data.title}</span>
            </a>
          ) : (
            <span class="post-nav__item post-nav__item--empty" aria-hidden="true"></span>
          )}
          {nextPost ? (
            <a class="post-nav__item post-nav__item--next" href={postHref(nextPost)}>
              <span class="kw-eyebrow post-nav__dir no-indent">次の記事 →</span>
              <span class="post-nav__title">{nextPost.data.title}</span>
            </a>
          ) : (
            <span class="post-nav__item post-nav__item--empty" aria-hidden="true"></span>
          )}
        </nav>
      )}

      {relatedPosts.length > 0 && (
        <section class="post-related" aria-label="関連記事">
          <p class="kw-eyebrow post-related__label no-indent">related</p>
          <ul class="post-related__list">
            {relatedPosts.map((entry) => (
              <li class="post-related__item">
                <a class="post-related__link" href={postHref(entry)}>
                  <span class="kw-mono post-related__meta">
                    <FormattedDate date={entry.data.pubDate} />
                    {entry.data.category && <span> · {entry.data.category}</span>}
                  </span>
                  <span class="post-related__title">{entry.data.title}</span>
                  <span class="post-related__arrow" aria-hidden="true">→</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}
    </article>
    {tocItems.length > 0 && (
      <aside class="toc-sidebar" aria-label="目次">
        <TableOfContents headings={headings} />
      </aside>
    )}
  </div>
</SiteLayout>

<script>
  const bindCopyButtons = () => {
    const buttons = document.querySelectorAll<HTMLButtonElement>('.post-share__copy');
    buttons.forEach((btn) => {
      if (btn.dataset.bound === '1') return;
      btn.dataset.bound = '1';
      btn.addEventListener('click', async () => {
        const url = btn.dataset.shareUrl;
        const textEl = btn.querySelector<HTMLElement>('.post-share__copy-text');
        if (!url || !textEl) return;
        const original = btn.dataset.copyLabel ?? textEl.textContent ?? '';
        const copied = btn.dataset.copiedLabel ?? 'コピーしました';
        try {
          await navigator.clipboard.writeText(url);
        } catch {
          return;
        }
        textEl.textContent = copied;
        btn.disabled = true;
        window.setTimeout(() => {
          textEl.textContent = original;
          btn.disabled = false;
        }, 1500);
      });
    });
  };

  bindCopyButtons();
  document.addEventListener('astro:page-load', bindCopyButtons);
</script>

<style>
  .post-layout {
    width: min(76ch, 100%);
    padding-block-start: var(--kw-space-12);
  }
  .post-wrap {
    display: contents;
  }
  .post {
    display: grid;
    gap: var(--kw-space-8);
  }
  .toc-mobile { display: block; }
  .toc-sidebar { display: none; }

  .post__hero {
    margin: 0;
    border-radius: var(--kw-radius-md);
    overflow: clip;
    border: 1px solid var(--kw-rule);
    display: flex;
    justify-content: center;
    align-items: center;
    background: var(--kw-bg-card);
  }
  .post__hero img {
    display: block;
    max-width: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  .post__header {
    text-align: start;
    display: grid;
    gap: var(--kw-space-4);
  }
  .post__meta {
    display: flex;
    gap: var(--kw-space-4);
    flex-wrap: wrap;
    font-size: var(--kw-fs-mono-sm);
    color: var(--kw-fg-muted);
  }
  .post__meta-date,
  .post__meta-update {
    font-family: var(--kw-font-mono);
  }
  .post__meta-update { font-style: italic; }

  .post__title {
    font-family: var(--kw-font-display);
    font-size: clamp(var(--kw-fs-display-sm), 4vw, var(--kw-fs-display-md));
    font-weight: var(--kw-fw-medium);
    letter-spacing: var(--kw-ls-display);
    line-height: var(--kw-lh-snug);
    color: var(--kw-fg-display);
    margin: 0;
  }

  .post__content {
    color: var(--kw-fg);
    overflow-wrap: break-word;
    word-wrap: break-word;
    line-height: var(--kw-lh-prose);
  }
  .post__content :global(img) {
    max-width: 100%;
    width: auto;
    height: auto;
    display: block;
    margin-inline: auto;
  }
  .post__content :global(pre) {
    overflow-x: auto;
    max-width: 100%;
  }
  .post__content :global(table) {
    display: block;
    overflow-x: auto;
    max-width: 100%;
  }
  .post__content :global(:where(* + *)) {
    margin-block-start: clamp(var(--kw-space-6), 3vw, var(--kw-space-10));
  }

  .post-share {
    display: grid;
    gap: var(--kw-space-3);
    padding-block-start: var(--kw-space-6);
    border-top: 1px solid var(--kw-rule);
  }
  .post-share__label {
    margin: 0;
  }
  .post-share__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--kw-space-3);
  }
  .post-share__btn {
    display: inline-flex;
    align-items: center;
    gap: var(--kw-space-2);
    font-family: var(--kw-font-mono);
    font-size: var(--kw-fs-mono-sm);
    color: var(--kw-fg-display);
    background: transparent;
    border: 1px solid var(--kw-rule);
    border-radius: var(--kw-radius-sm);
    padding: var(--kw-space-2) var(--kw-space-4);
    cursor: pointer;
    text-decoration: none;
    transition:
      border-color var(--kw-duration-fast) var(--kw-easing),
      color var(--kw-duration-fast) var(--kw-easing),
      background var(--kw-duration-fast) var(--kw-easing);
  }
  .post-share__btn:hover {
    border-color: var(--kw-fg-link);
    color: var(--kw-fg-link);
  }
  .post-share__btn:disabled {
    cursor: default;
    color: var(--kw-fg-muted);
    border-color: var(--kw-rule);
  }
  .post-share__btn-arrow {
    color: var(--kw-accent);
    font-family: var(--kw-font-display);
  }

  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--kw-space-4);
    padding-block-start: var(--kw-space-6);
    border-top: 1px solid var(--kw-rule);
  }
  .post-nav__item {
    display: grid;
    gap: var(--kw-space-2);
    padding: var(--kw-space-4);
    border: 1px solid var(--kw-rule);
    border-radius: var(--kw-radius-md);
    background: var(--kw-bg-card);
    color: var(--kw-fg-display);
    text-decoration: none;
    transition:
      border-color var(--kw-duration-fast) var(--kw-easing),
      transform var(--kw-duration-fast) var(--kw-easing);
  }
  .post-nav__item--empty {
    background: transparent;
    border-color: transparent;
    pointer-events: none;
  }
  .post-nav__item--next {
    text-align: end;
  }
  a.post-nav__item:hover {
    border-color: var(--kw-fg-link);
    transform: translateY(-2px);
  }
  .post-nav__dir {
    color: var(--kw-fg-muted);
  }
  .post-nav__title {
    font-family: var(--kw-font-display);
    font-size: var(--kw-fs-md);
    line-height: var(--kw-lh-snug);
  }

  .post-related {
    display: grid;
    gap: var(--kw-space-4);
    padding-block-start: var(--kw-space-6);
    border-top: 1px solid var(--kw-rule);
  }
  .post-related__label {
    margin: 0;
  }
  .post-related__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--kw-space-2);
  }
  .post-related__link {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: baseline;
    gap: var(--kw-space-4);
    padding: var(--kw-space-3) var(--kw-space-4);
    border: 1px solid transparent;
    border-radius: var(--kw-radius-sm);
    color: var(--kw-fg-display);
    text-decoration: none;
    transition:
      border-color var(--kw-duration-fast) var(--kw-easing),
      background var(--kw-duration-fast) var(--kw-easing);
  }
  .post-related__link:hover {
    border-color: var(--kw-rule);
    background: var(--kw-bg-card);
  }
  .post-related__meta {
    color: var(--kw-fg-muted);
    font-size: var(--kw-fs-mono-sm);
    white-space: nowrap;
  }
  .post-related__title {
    font-family: var(--kw-font-display);
    font-size: var(--kw-fs-md);
    line-height: var(--kw-lh-snug);
  }
  .post-related__arrow {
    color: var(--kw-accent);
    font-family: var(--kw-font-display);
  }

  @media (min-width: 901px) {
    :global(.post-layout) {
      width: min(100%, 112ch);
    }
    .post-wrap {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 15rem;
      gap: clamp(var(--kw-space-8), 4vw, var(--kw-space-12));
      align-items: start;
    }
    .post {
      grid-column: 1;
      grid-row: 1;
    }
    .toc-mobile { display: none; }
    .toc-sidebar {
      display: block;
      grid-column: 2;
      grid-row: 1;
      position: sticky;
      top: clamp(var(--kw-space-6), 3vw, var(--kw-space-8));
      max-height: calc(100vh - 5rem);
      overflow-y: auto;
    }
  }

  @media (max-width: 720px) {
    .post-layout {
      padding-block-start: var(--kw-space-8);
    }
    .post-nav {
      grid-template-columns: 1fr;
    }
    .post-nav__item--next {
      text-align: start;
    }
    .post-related__link {
      grid-template-columns: 1fr auto;
    }
    .post-related__meta {
      grid-column: 1 / -1;
    }
  }
</style>
