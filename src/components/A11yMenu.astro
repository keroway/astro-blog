---
// a11y 表示設定メニュー (issue #390)
// モーション低減・文字サイズ・読書補助を提供する。設定は localStorage に永続化し、
// FOUC 防止の初期適用は BaseHead.astro の head inline が担う。
---

<div class="a11y-menu">
  <button
    id="a11y-trigger"
    class="a11y-menu__trigger"
    type="button"
    popovertarget="a11y-panel"
    aria-haspopup="dialog"
    aria-controls="a11y-panel"
    aria-label="表示設定を開く"
  >
    <span aria-hidden="true">⚙</span>
  </button>

  <div
    id="a11y-panel"
    class="a11y-menu__panel"
    popover="auto"
    role="dialog"
    aria-label="表示設定"
  >
    <p class="a11y-menu__title">表示設定</p>

    <fieldset class="a11y-menu__fieldset">
      <legend class="a11y-menu__legend">動き</legend>
      <label class="a11y-menu__row">
        <input id="a11y-reduce-motion" type="checkbox" autofocus />
        <span>モーションを減らす</span>
      </label>
    </fieldset>

    <fieldset class="a11y-menu__fieldset">
      <legend class="a11y-menu__legend">読みやすさ</legend>
      <div class="a11y-menu__segment" role="radiogroup" aria-label="文字サイズ">
        <label class="a11y-menu__radio">
          <input type="radio" name="a11y-font-size" value="normal" />
          <span>標準</span>
        </label>
        <label class="a11y-menu__radio">
          <input type="radio" name="a11y-font-size" value="large" />
          <span>大</span>
        </label>
        <label class="a11y-menu__radio">
          <input type="radio" name="a11y-font-size" value="x-large" />
          <span>特大</span>
        </label>
      </div>
      <label class="a11y-menu__row">
        <input id="a11y-text-spacing" type="checkbox" />
        <span>行間・字間を広げる</span>
      </label>
      <label class="a11y-menu__row">
        <input id="a11y-underline-links" type="checkbox" />
        <span>リンクに常時下線</span>
      </label>
    </fieldset>

    <button id="a11y-reset" class="a11y-menu__reset" type="button">初期設定に戻す</button>
  </div>
</div>

<script>
  import {
    REDUCE_MOTION_KEY,
    applyMotionPreferences,
    manualReduceMotion,
    setReduceMotion,
  } from '../scripts/reduce-motion';
  import {
    FONT_SIZE_KEY,
    getFontSize,
    setFontSize,
    type FontSize,
  } from '../scripts/font-size';
  import {
    TEXT_SPACING_KEY,
    applyTextSpacingPreference,
    getTextSpacing,
    setTextSpacing,
  } from '../scripts/text-spacing';
  import {
    UNDERLINE_LINKS_KEY,
    applyUnderlineLinksPreference,
    getUnderlineLinks,
    setUnderlineLinks,
  } from '../scripts/underline-links';

  // Popover API (issue #503) へ移行。開閉・light-dismiss・Esc 閉じ・トップレイヤー表示・
  // フォーカス管理はブラウザネイティブ (popover 属性 + popovertarget) が担うため、
  // ここでは各コントロールの状態同期と設定反映のみを行う。
  function panel() {
    return document.getElementById('a11y-panel');
  }

  function init() {
    const p = panel();
    if (!p) return;

    // 初期状態を同期
    const reduceInput = document.getElementById(
      'a11y-reduce-motion'
    ) as HTMLInputElement | null;
    if (reduceInput) reduceInput.checked = manualReduceMotion();

    const current = getFontSize();
    for (const r of p.querySelectorAll<HTMLInputElement>(
      'input[name="a11y-font-size"]'
    )) {
      r.checked = r.value === current;
    }

    const spacingInput = document.getElementById(
      'a11y-text-spacing'
    ) as HTMLInputElement | null;
    if (spacingInput) spacingInput.checked = getTextSpacing();

    const underlineInput = document.getElementById(
      'a11y-underline-links'
    ) as HTMLInputElement | null;
    if (underlineInput) underlineInput.checked = getUnderlineLinks();

    const resetButton = document.getElementById('a11y-reset');

    // コントロール
    reduceInput?.addEventListener('change', () => {
      setReduceMotion(reduceInput.checked ? 'on' : 'off');
    });
    for (const r of p.querySelectorAll<HTMLInputElement>(
      'input[name="a11y-font-size"]'
    )) {
      r.addEventListener('change', () => {
        if (r.checked) setFontSize(r.value as FontSize);
      });
    }
    spacingInput?.addEventListener('change', () => {
      setTextSpacing(spacingInput.checked);
    });
    underlineInput?.addEventListener('change', () => {
      setUnderlineLinks(underlineInput.checked);
    });
    resetButton?.addEventListener('click', () => {
      try {
        localStorage.removeItem(REDUCE_MOTION_KEY);
        localStorage.removeItem(FONT_SIZE_KEY);
        localStorage.removeItem(TEXT_SPACING_KEY);
        localStorage.removeItem(UNDERLINE_LINKS_KEY);
      } catch (e) {}
      applyMotionPreferences();
      document.documentElement.classList.remove('fs-large', 'fs-x-large');
      applyTextSpacingPreference();
      applyUnderlineLinksPreference();
      if (reduceInput) reduceInput.checked = manualReduceMotion();
      for (const r of p.querySelectorAll<HTMLInputElement>(
        'input[name="a11y-font-size"]'
      )) {
        r.checked = r.value === 'normal';
      }
      if (spacingInput) spacingInput.checked = false;
      if (underlineInput) underlineInput.checked = false;
    });
  }

  // 初回ロードと View Transitions 遷移後の両方で初期化
  document.addEventListener('astro:page-load', init);
</script>

<style>
  .a11y-menu {
    position: relative;
    display: flex;
    align-items: center;
  }

  .a11y-menu__trigger {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    min-height: 44px;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--kw-fg-muted);
    font-size: var(--kw-fs-body);
    line-height: 1;
    padding: var(--kw-space-2);
    border-radius: var(--kw-radius-sm);
    transition: color var(--kw-duration-fast) var(--kw-easing);
  }
  .a11y-menu__trigger:hover {
    color: var(--kw-fg-display);
  }
  .a11y-menu__trigger:focus-visible {
    outline: 2px solid var(--kw-accent);
    outline-offset: 2px;
  }

  /* -------------------------------------------------------------
   * Popover API + Anchor Positioning + @starting-style (issue #503)
   *
   * パネルは popover="auto" でトップレイヤーに表示されるため、UA 既定の
   * inset:0 / margin:auto (中央寄せ) をリセットする。
   * フォールバック: Anchor Positioning 未対応 (Firefox 等) では fixed で
   * ヘッダー右下に配置する。対応ブラウザでは @supports でアンカーに紐付ける。
   * ------------------------------------------------------------- */
  .a11y-menu__panel {
    position: fixed;
    inset: auto;
    top: var(--kw-space-16);
    right: var(--kw-space-4);
    margin: 0;
    z-index: 60;
    min-width: 260px;
    max-height: min(70vh, 520px);
    overflow-y: auto;
    padding: var(--kw-space-4);
    background: var(--kw-bg-card);
    border: 1px solid var(--kw-rule-strong);
    border-radius: var(--kw-radius-md);
    box-shadow: var(--kw-shadow-pop);
    display: flex;
    flex-direction: column;
    gap: var(--kw-space-4);
  }

  /* Popover 非対応ブラウザでは popover 属性が無視され、UA の
   * [popover]:not(:popover-open){display:none} が効かない。不可視の fixed パネルが
   * クリックを奴うのを防ぐため、非対応時は完全に非表示にする。 */
  @supports not (selector(:popover-open)) {
    .a11y-menu__panel {
      display: none;
    }
  }

  /* 開閉トランジション: フェード + スライド。--kw-motion-* トークンに接続し、
   * reduce-motion 時は global.css が distance=0 / duration≈0 に倒す。
   * transition は開・閉両方で発火させるため両状態に適用する。 */
  .a11y-menu__panel:popover-open {
    opacity: 1;
    translate: 0 0;
  }
  .a11y-menu__panel,
  .a11y-menu__panel:popover-open {
    transition:
      opacity var(--kw-motion-duration) var(--kw-motion-easing),
      translate var(--kw-motion-duration) var(--kw-motion-easing),
      overlay var(--kw-motion-duration) allow-discrete,
      display var(--kw-motion-duration) allow-discrete;
  }
  .a11y-menu__panel {
    opacity: 0;
    translate: 0 calc(-1 * var(--kw-motion-distance));
  }
  @starting-style {
    .a11y-menu__panel:popover-open {
      opacity: 0;
      translate: 0 calc(-1 * var(--kw-motion-distance));
    }
  }

  /* Anchor Positioning 対応ブラウザではトリガーに紐付け、画面端で自動フリップ。 */
  @supports (anchor-name: --a11y-anchor) {
    .a11y-menu__trigger {
      anchor-name: --a11y-anchor;
    }
    .a11y-menu__panel {
      position-anchor: --a11y-anchor;
      position-area: bottom span-left;
      top: auto;
      right: auto;
      margin-block-start: var(--kw-space-3);
      position-try-fallbacks: flip-block, flip-inline;
    }
  }

  .a11y-menu__title {
    margin: 0;
    font-family: var(--kw-font-mono);
    font-size: var(--kw-fs-mono-sm);
    text-transform: uppercase;
    letter-spacing: var(--kw-ls-eyebrow-ja);
    color: var(--kw-fg-faint);
  }

  .a11y-menu__row {
    display: flex;
    align-items: center;
    gap: var(--kw-space-3);
    font-size: var(--kw-fs-body-sm);
    color: var(--kw-fg);
    cursor: pointer;
  }

  .a11y-menu__fieldset {
    margin: 0;
    padding: 0 0 var(--kw-space-3);
    border: 0;
    border-bottom: 1px solid var(--kw-rule);
    display: grid;
    gap: var(--kw-space-3);
  }
  .a11y-menu__legend {
    padding: 0;
    margin-bottom: var(--kw-space-2);
    font-family: var(--kw-font-mono);
    font-size: var(--kw-fs-mono-sm);
    color: var(--kw-fg-faint);
  }
  .a11y-menu__segment {
    display: flex;
    flex-wrap: wrap;
    gap: var(--kw-space-4);
  }
  .a11y-menu__radio {
    display: flex;
    align-items: center;
    gap: var(--kw-space-2);
    font-size: var(--kw-fs-body-sm);
    color: var(--kw-fg);
    cursor: pointer;
  }

  .a11y-menu__reset {
    align-self: flex-start;
    padding: var(--kw-space-2) var(--kw-space-3);
    border: 1px solid var(--kw-rule-strong);
    border-radius: var(--kw-radius-sm);
    background: transparent;
    color: var(--kw-fg);
    font-family: var(--kw-font-mono);
    font-size: var(--kw-fs-mono-sm);
    cursor: pointer;
  }
  .a11y-menu__reset:hover {
    border-color: var(--kw-accent-strong);
    color: var(--kw-fg-display);
  }

  .a11y-menu input:focus-visible,
  .a11y-menu__reset:focus-visible {
    outline: 2px solid var(--kw-accent);
    outline-offset: 2px;
  }

  @media (max-width: 640px) {
    .a11y-menu__panel {
      right: var(--kw-space-3);
    }
  }
</style>
