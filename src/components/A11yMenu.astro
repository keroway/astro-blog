---
// a11y 表示設定メニュー (issue #378)
// モーション低減トグルと文字サイズ切替を提供する。設定は localStorage に永続化し、
// FOUC 防止の初期適用は BaseHead.astro の head inline が担う。
---

<div class="a11y-menu">
  <button
    id="a11y-trigger"
    class="a11y-menu__trigger"
    type="button"
    aria-haspopup="dialog"
    aria-expanded="false"
    aria-controls="a11y-panel"
    aria-label="表示設定を開く"
  >
    <span aria-hidden="true">⚙</span>
  </button>

  <div
    id="a11y-panel"
    class="a11y-menu__panel"
    role="dialog"
    aria-label="表示設定"
    aria-modal="false"
    hidden
  >
    <p class="a11y-menu__title">表示設定</p>

    <label class="a11y-menu__row">
      <input id="a11y-reduce-motion" type="checkbox" />
      <span>モーションを減らす</span>
    </label>

    <fieldset class="a11y-menu__fieldset">
      <legend class="a11y-menu__legend">文字サイズ</legend>
      <div class="a11y-menu__segment" role="radiogroup" aria-label="文字サイズ">
        <label class="a11y-menu__radio">
          <input type="radio" name="a11y-font-size" value="normal" />
          <span>標準</span>
        </label>
        <label class="a11y-menu__radio">
          <input type="radio" name="a11y-font-size" value="large" />
          <span>大</span>
        </label>
      </div>
    </fieldset>
  </div>
</div>

<script>
  import { manualReduceMotion, setReduceMotion } from '../scripts/reduce-motion';
  import { getFontSize, setFontSize } from '../scripts/font-size';

  function panel() {
    return document.getElementById('a11y-panel');
  }
  function trigger() {
    return document.getElementById('a11y-trigger');
  }

  function isOpen() {
    return trigger()?.getAttribute('aria-expanded') === 'true';
  }

  function open() {
    const t = trigger();
    const p = panel();
    if (!t || !p) return;
    t.setAttribute('aria-expanded', 'true');
    p.hidden = false;
    // 最初のコントロールへフォーカス
    p.querySelector<HTMLElement>('input, button')?.focus();
  }

  function close(returnFocus = true) {
    const t = trigger();
    const p = panel();
    if (!t || !p) return;
    t.setAttribute('aria-expanded', 'false');
    p.hidden = true;
    if (returnFocus) t.focus();
  }

  function init() {
    const t = trigger();
    const p = panel();
    if (!t || !p) return;

    // 初期状態を同期
    const reduceInput = document.getElementById(
      'a11y-reduce-motion'
    ) as HTMLInputElement | null;
    if (reduceInput) reduceInput.checked = manualReduceMotion();

    const current = getFontSize();
    for (const r of p.querySelectorAll<HTMLInputElement>(
      'input[name="a11y-font-size"]'
    )) {
      r.checked = r.value === current;
    }

    // トリガー開閉
    t.addEventListener('click', () => {
      isOpen() ? close() : open();
    });

    // コントロール
    reduceInput?.addEventListener('change', () => {
      setReduceMotion(reduceInput.checked ? 'on' : 'off');
    });
    for (const r of p.querySelectorAll<HTMLInputElement>(
      'input[name="a11y-font-size"]'
    )) {
      r.addEventListener('change', () => {
        if (r.checked) setFontSize(r.value === 'large' ? 'large' : 'normal');
      });
    }
  }

  // Esc で閉じる / 外側クリックで閉じる (document に一度だけ登録)
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen()) close();
  });
  document.addEventListener('click', (e) => {
    if (!isOpen()) return;
    const target = e.target as Node;
    if (!document.querySelector('.a11y-menu')?.contains(target)) close(false);
  });

  // 初回ロードと View Transitions 遷移後の両方で初期化
  document.addEventListener('astro:page-load', init);
</script>

<style>
  .a11y-menu {
    position: relative;
    display: flex;
    align-items: center;
  }

  .a11y-menu__trigger {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--kw-fg-muted);
    font-size: var(--kw-fs-body-sm);
    line-height: 1;
    padding: var(--kw-space-1) var(--kw-space-2);
    border-radius: var(--kw-radius-sm);
    transition: color var(--kw-duration-fast) var(--kw-easing);
  }
  .a11y-menu__trigger:hover {
    color: var(--kw-fg-display);
  }
  .a11y-menu__trigger:focus-visible {
    outline: 2px solid var(--kw-accent);
    outline-offset: 2px;
  }

  .a11y-menu__panel {
    position: absolute;
    top: calc(100% + var(--kw-space-3));
    right: 0;
    z-index: 60;
    min-width: 220px;
    padding: var(--kw-space-4);
    background: var(--kw-bg-card);
    border: 1px solid var(--kw-rule-strong);
    border-radius: var(--kw-radius-md);
    box-shadow: var(--kw-shadow-pop);
    display: flex;
    flex-direction: column;
    gap: var(--kw-space-4);
  }

  .a11y-menu__title {
    margin: 0;
    font-family: var(--kw-font-mono);
    font-size: var(--kw-fs-mono-sm);
    text-transform: uppercase;
    letter-spacing: var(--kw-ls-eyebrow-ja);
    color: var(--kw-fg-faint);
  }

  .a11y-menu__row {
    display: flex;
    align-items: center;
    gap: var(--kw-space-3);
    font-size: var(--kw-fs-body-sm);
    color: var(--kw-fg);
    cursor: pointer;
  }

  .a11y-menu__fieldset {
    margin: 0;
    padding: 0;
    border: 0;
  }
  .a11y-menu__legend {
    padding: 0;
    margin-bottom: var(--kw-space-2);
    font-size: var(--kw-fs-body-sm);
    color: var(--kw-fg);
  }
  .a11y-menu__segment {
    display: flex;
    gap: var(--kw-space-4);
  }
  .a11y-menu__radio {
    display: flex;
    align-items: center;
    gap: var(--kw-space-2);
    font-size: var(--kw-fs-body-sm);
    color: var(--kw-fg);
    cursor: pointer;
  }

  .a11y-menu input:focus-visible {
    outline: 2px solid var(--kw-accent);
    outline-offset: 2px;
  }

  @media (max-width: 640px) {
    .a11y-menu__panel {
      right: 0;
    }
  }
</style>
