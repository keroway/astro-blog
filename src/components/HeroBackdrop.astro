---
/**
 * HeroBackdrop — HERO 背景の装飾（モチーフ語彙: 富士の遠景 + 道筋 + 地点 + 水面）
 *
 * 横浜近郊の浮世絵語彙（design-system.md §9 / ADR 0007・0011）を 1 枚の
 * インライン SVG に統合する。新色は足さず、既存トークン
 * (--kw-fuji / --kw-rule(-soft) / --kw-sand) のみで描く。
 *
 * - aria-hidden の純粋な装飾（情報を持たない）
 * - 静止（モーションなし）。CLS を出さない（absolute inset:0 で .hero に重なるだけ）
 * - preserveAspectRatio="none" で .hero の比率に追従（既存 .kw-watermark-fuji と同じ振る舞い）
 * - ≤900px では道筋・地点・水面を隠し、富士のみ残して簡略化
 */
---

<div class="hero-backdrop" aria-hidden="true" role="presentation">
  <svg
    class="hero-backdrop__svg"
    viewBox="0 0 1200 700"
    preserveAspectRatio="none"
    focusable="false"
    aria-hidden="true"
  >
    <!-- 富士の遠景: 程ヶ谷越しの稜線（既存 .kw-watermark-fuji の形状を SVG 化） -->
    <polygon
      class="hero-backdrop__fuji"
      points="0,700 180,700 324,385 504,70 576,14 600,28 624,14 696,70 876,385 1020,700 1200,700"
    />

    <!-- 道筋: 左上→右下へゆるく抜ける一本の街道 -->
    <path
      class="hero-backdrop__road"
      d="M 70 110 C 360 250, 620 350, 1140 600"
      fill="none"
    />

    <!-- 地点（宿場）: 道筋上の中継点を示す小円 -->
    <g class="hero-backdrop__stations">
      <circle cx="232" cy="190" r="6" />
      <circle cx="520" cy="318" r="6" />
      <circle cx="812" cy="448" r="6" />
      <circle cx="1064" cy="566" r="6" />
    </g>

    <!-- 水面の水平線: 横浜の海を示唆する薄い水平線 -->
    <g class="hero-backdrop__water">
      <line x1="0" y1="636" x2="1200" y2="636" />
      <line x1="0" y1="664" x2="1200" y2="664" />
    </g>
  </svg>
</div>

<style>
  .hero-backdrop {
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    user-select: none;
    overflow: hidden;
  }
  .hero-backdrop__svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* 富士の遠景 — 既存ウォーターマークと同じ極薄の塗り */
  .hero-backdrop__fuji {
    fill: var(--kw-fuji);
    opacity: 0.06;
  }

  /* 道筋 — 遠景の藍で細く、ごく薄く */
  .hero-backdrop__road {
    stroke: var(--kw-fuji);
    stroke-width: 2;
    stroke-linecap: round;
    opacity: 0.22;
    vector-effect: non-scaling-stroke;
  }

  /* 地点 — 砂金アクセントを控えめに */
  .hero-backdrop__stations circle {
    fill: var(--kw-sand);
    opacity: 0.5;
  }

  /* 水面 — 既存の薄罫線トークンで水平線 */
  .hero-backdrop__water line {
    stroke: var(--kw-rule-soft);
    stroke-width: 1;
    vector-effect: non-scaling-stroke;
  }

  /* モバイルでは装飾を簡略化（道筋・地点・水面を隠し、富士のみ残す） */
  @media (max-width: 900px) {
    .hero-backdrop__road,
    .hero-backdrop__stations,
    .hero-backdrop__water {
      display: none;
    }
  }
</style>
