---
/**
 * HeroBackdrop — HERO 背景の装飾（モチーフ語彙: 富士の遠景 + 道筋 + 地点 + 水面）
 *
 * 横浜近郊の浮世絵語彙（design-system.md §9 / ADR 0007・0011・0012）を 1 枚の
 * インライン SVG に統合する。ADR 0012 により、道筋は専用トークン
 * (--kw-road / --kw-road-soft) でやや強く扱う。
 *
 * - aria-hidden の純粋な装飾（情報を持たない）
 * - 静止（モーションなし）。CLS を出さない（absolute inset:0 で .hero に重なるだけ）
 * - preserveAspectRatio="none" で .hero の比率に追従（既存 .kw-watermark-fuji と同じ振る舞い）
 * - ≤640px では地名ラベルと細部を隠し、道筋の印象だけ残す
 */
---

<div class="hero-backdrop" aria-hidden="true" role="presentation">
  <svg
    class="hero-backdrop__svg"
    viewBox="0 0 1200 700"
    preserveAspectRatio="none"
    focusable="false"
    aria-hidden="true"
  >
    <defs>
      <filter id="hero-backdrop-roughen" x="-10%" y="-10%" width="120%" height="120%">
        <feTurbulence type="fractalNoise" baseFrequency="0.018" numOctaves="2" seed="17" />
        <feDisplacementMap in="SourceGraphic" scale="2.4" />
      </filter>
    </defs>

    <!-- 富士の遠景: 程ヶ谷越しの稜線（既存 .kw-watermark-fuji の形状を SVG 化） -->
    <polygon
      class="hero-backdrop__fuji"
      points="0,700 180,700 324,385 504,70 576,14 600,28 624,14 696,70 876,385 1020,700 1200,700"
    />

    <!-- 道筋: 左上→右下へゆるく抜ける一本の街道 -->
    <path
      class="hero-backdrop__road-band"
      d="M 18 132 C 170 78, 322 224, 480 250 C 642 278, 718 158, 852 174 C 980 190, 1034 330, 1162 554"
      fill="none"
    />
    <path
      class="hero-backdrop__road"
      d="M 18 132 C 170 78, 322 224, 480 250 C 642 278, 718 158, 852 174 C 980 190, 1034 330, 1162 554"
      fill="none"
    />

    <!-- 地点（宿場）: 道筋上の中継点を示す小円 -->
    <g class="hero-backdrop__stations">
      <circle cx="166" cy="100" r="7" />
      <circle cx="478" cy="250" r="7" />
      <circle cx="846" cy="174" r="7" />
      <circle cx="1088" cy="430" r="7" />
    </g>

    <g class="hero-backdrop__labels">
      <text x="132" y="156">戸塚</text>
      <text x="448" y="320">程ヶ谷</text>
      <text x="812" y="238">神奈川</text>
      <text x="1036" y="492">横浜</text>
    </g>

    <!-- 水面の水平線: 横浜の海を示唆する薄い水平線 -->
    <g class="hero-backdrop__water">
      <line x1="0" y1="636" x2="1200" y2="636" />
      <line x1="0" y1="664" x2="1200" y2="664" />
    </g>
  </svg>
</div>

<style>
  .hero-backdrop {
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    user-select: none;
    overflow: hidden;
  }
  .hero-backdrop::before {
    content: '';
    position: absolute;
    inset: -1px;
    background:
      linear-gradient(90deg, transparent 0 72%, var(--kw-accent-strong-soft) 72% 73%, transparent 73%),
      repeating-linear-gradient(
        0deg,
        transparent 0,
        transparent 31px,
        var(--kw-rule-soft) 32px
      );
    opacity: 0.75;
  }
  .hero-backdrop__svg {
    position: relative;
    width: 100%;
    height: 100%;
    display: block;
  }

  /* 富士の遠景 — 既存ウォーターマークと同じ極薄の塗り */
  .hero-backdrop__fuji {
    fill: var(--kw-fuji);
    opacity: 0.09;
  }

  /* 道筋 — ADR 0012 により HERO の主装飾として少し強く扱う */
  .hero-backdrop__road-band {
    stroke: var(--kw-road-soft);
    stroke-width: 28;
    stroke-linecap: round;
    opacity: 1;
    filter: url(#hero-backdrop-roughen);
    vector-effect: non-scaling-stroke;
  }
  .hero-backdrop__road {
    stroke: var(--kw-road);
    stroke-width: 2.4;
    stroke-linecap: round;
    stroke-dasharray: 3 10;
    opacity: 0.82;
    vector-effect: non-scaling-stroke;
  }

  /* 地点 — 朱と砂金を重ねた宿場印 */
  .hero-backdrop__stations circle {
    fill: var(--kw-accent-strong);
    opacity: 0.82;
    stroke: var(--kw-sand);
    stroke-width: 2;
    vector-effect: non-scaling-stroke;
  }

  .hero-backdrop__labels text {
    font-family: var(--kw-font-display);
    font-size: 18px;
    letter-spacing: 0;
    writing-mode: vertical-rl;
    fill: var(--kw-fg-faint);
    opacity: 0.7;
  }

  /* 水面 — 既存の薄罫線トークンで水平線 */
  .hero-backdrop__water line {
    stroke: var(--kw-rule-soft);
    stroke-width: 1;
    vector-effect: non-scaling-stroke;
  }

  @media (max-width: 640px) {
    .hero-backdrop::before,
    .hero-backdrop__labels,
    .hero-backdrop__water {
      display: none;
    }
    .hero-backdrop__road-band {
      stroke-width: 18;
      opacity: 0.8;
    }
    .hero-backdrop__road {
      opacity: 0.6;
    }
    .hero-backdrop__stations circle {
      opacity: 0.55;
    }
  }
</style>
