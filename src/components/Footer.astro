---
import Monogram from './Monogram.astro';
---

<footer class="kw-footer" role="contentinfo">
  <div class="kw-footer__left">
    <p class="kw-footer__eyebrow">colophon</p>
    <h2 class="kw-footer__head">
      <span class="kw-footer__head-alt">連絡</span>、待っています。
    </h2>
    <p class="kw-footer__built no-indent">Built with Astro · Hosted on Vercel · yokohama</p>
    <div class="kw-footer__monogram">
      <Monogram />
    </div>
  </div>

  <ul class="kw-footer__links" aria-label="external links">
    <li>
      <a href="https://twitter.com/keroway21" class="kw-footer__link" rel="me noopener noreferrer" target="_blank">
        <span class="sr-only">keroway on Twitter</span>
        <span class="kw-footer__link-arrow" aria-hidden="true">→</span>
        <span aria-hidden="true">twitter.com/keroway21</span>
      </a>
    </li>
    <li>
      <a href="https://github.com/keroway" class="kw-footer__link" rel="me noopener noreferrer" target="_blank">
        <span class="sr-only">keroway on GitHub</span>
        <span class="kw-footer__link-arrow" aria-hidden="true">→</span>
        <span aria-hidden="true">github.com/keroway</span>
      </a>
    </li>
    <li>
      <a href="/rss.xml" class="kw-footer__link">
        <span class="kw-footer__link-arrow" aria-hidden="true">→</span>
        <span>/rss.xml</span>
      </a>
    </li>
  </ul>
</footer>

<style>
  .kw-footer {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--kw-space-10);
    align-items: end;
    padding: var(--kw-space-12) var(--kw-space-10);
    border-top: 1px solid var(--kw-rule);
    background: var(--kw-bg);
  }

  .kw-footer__eyebrow {
    font-family: var(--kw-font-mono);
    font-size: var(--kw-fs-mono-xs);
    text-transform: uppercase;
    letter-spacing: var(--kw-ls-eyebrow);
    color: var(--kw-fg-link);
    margin: 0 0 var(--kw-space-3);
    text-indent: 0;
  }

  .kw-footer__head {
    font-family: var(--kw-font-display);
    font-size: var(--kw-fs-display-md);
    font-weight: var(--kw-fw-medium);
    line-height: 1.15;
    letter-spacing: var(--kw-ls-display);
    color: var(--kw-fg-display);
    margin: 0;
  }
  .kw-footer__head-alt { color: var(--kw-fg-link); }

  .kw-footer__built {
    font-family: var(--kw-font-mono);
    font-size: var(--kw-fs-mono-sm);
    color: var(--kw-fg-muted);
    margin: var(--kw-space-4) 0 var(--kw-space-6);
    text-indent: 0;
  }

  .kw-footer__monogram {
    display: flex;
  }

  .kw-footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--kw-space-2);
    align-items: flex-end;
  }

  .kw-footer__link {
    display: flex;
    align-items: center;
    gap: var(--kw-space-3);
    font-family: var(--kw-font-mono);
    font-size: var(--kw-fs-body-sm);
    color: var(--kw-fg-display);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding: 2px 0;
    transition: border-color var(--kw-duration-fast) var(--kw-easing);
  }
  .kw-footer__link:hover {
    border-bottom-color: var(--kw-fg-link);
  }
  .kw-footer__link-arrow {
    color: var(--kw-accent);
    font-family: var(--kw-font-display);
  }

  .sr-only {
    position: absolute !important;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: 0;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 720px) {
    .kw-footer {
      grid-template-columns: 1fr;
      padding: var(--kw-space-8) var(--kw-space-5);
    }
    .kw-footer__head {
      font-size: var(--kw-fs-display-sm);
    }
    .kw-footer__links {
      align-items: flex-start;
    }
  }
</style>
