---
interface Props {
  label?: string;
  detail?: string;
  size?: 'sm' | 'md' | 'lg';
}

const { label = 'K', detail = '記', size = 'md' } = Astro.props;
---

<span class:list={['k-seal', `k-seal--${size}`]} aria-hidden="true">
  <span class="k-seal__label">{label}</span>
  <span class="k-seal__detail">{detail}</span>
</span>

<style>
  .k-seal {
    position: relative;
    display: inline-grid;
    place-items: center;
    inline-size: 56px;
    block-size: 56px;
    border: 1px solid var(--kw-seal-border);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.18), transparent 40%),
      var(--kw-seal-bg);
    border-radius: var(--kw-radius-sm);
    color: var(--kw-seal-fg);
    box-shadow: 0 10px 24px rgba(180, 61, 47, 0.18);
    transform: rotate(-4deg);
    transition: transform var(--kw-duration-normal) var(--kw-easing-spring);
    user-select: none;
  }
  @media (hover: hover) {
    .k-seal:hover {
      transform: rotate(-4deg) scale(1.06);
    }
  }

  .k-seal::after {
    content: '';
    position: absolute;
    inset: 5px;
    border: 1px solid color-mix(in srgb, var(--kw-seal-fg) 38%, transparent);
    border-radius: var(--kw-radius-xs);
    pointer-events: none;
  }
  .k-seal__label {
    font-family: var(--kw-font-display);
    font-size: 28px;
    line-height: 0.9;
    letter-spacing: 0;
    transform: translateX(-2px);
  }
  .k-seal__detail {
    font-family: var(--kw-font-display);
    font-size: 9px;
    font-weight: var(--kw-fw-medium);
    line-height: 1;
    letter-spacing: 0;
    writing-mode: vertical-rl;
    position: absolute;
    inset-inline-end: 9px;
    opacity: 0.86;
  }
  .k-seal--sm {
    inline-size: 40px;
    block-size: 40px;
  }
  .k-seal--sm .k-seal__label {
    font-size: 21px;
  }
  .k-seal--sm .k-seal__detail {
    display: none;
  }
  .k-seal--lg {
    inline-size: 72px;
    block-size: 72px;
  }
  .k-seal--lg .k-seal__label {
    font-size: 36px;
  }
  .k-seal--lg .k-seal__detail {
    inset-inline-end: 11px;
    font-size: 10px;
  }
</style>
