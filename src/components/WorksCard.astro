---
import type { WorksEntry } from "../types/content";
import { encodeSlugId } from "../lib/slug";
import { resolveWorksDate } from "../lib/content";

interface Props {
  work: WorksEntry;
  variant?: "grid" | "featured";
}

const { work, variant = "grid" } = Astro.props;

const statusMap = {
  active:   { label: "Active",   className: "kw-chip--status-active"   },
  wip:      { label: "WIP",      className: "kw-chip--status-wip"      },
  archived: { label: "Archived", className: "kw-chip--status-archived" },
} as const;

const status = statusMap[work.data.status];
const href = `/works/${encodeSlugId(work.id)}/`;
const releaseDate = resolveWorksDate(work);
const timestamp = releaseDate.toISOString();
const releaseLabel = releaseDate.toLocaleDateString("ja-JP", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<article class:list={["work-card", `work-card--${variant}`]}>
  <div class="work-card__body">
    <div class="work-card__meta">
      <span class:list={["kw-chip", status.className]}>{status.label}</span>
      <time class="kw-mono work-card__date" datetime={timestamp}>{releaseLabel}</time>
    </div>
    <h3 class="work-card__title">
      <a href={href}>{work.data.title}</a>
    </h3>
    <p class="work-card__description no-indent">{work.data.description}</p>
    <ul class="work-card__tags" aria-label="使用技術">
      {work.data.tags.map((tag) => (
        <li><span class="kw-chip work-card__tag">{tag}</span></li>
      ))}
    </ul>
    <div class="work-card__actions">
      <a class="kw-button work-card__btn" href={href}>Overview <span class="kw-button-arrow">→</span></a>
      <a class="work-card__external" href={work.data.lpUrl} target="_blank" rel="noopener noreferrer">
        LP を見る
      </a>
    </div>
  </div>
</article>

<style>
  .work-card {
    background: var(--kw-bg-card);
    border: 1px solid var(--kw-rule);
    border-radius: var(--kw-radius-md);
    min-height: 100%;
    transition: border-color var(--kw-duration-fast) var(--kw-easing);
  }
  .work-card:is(:hover, :focus-within) {
    border-color: var(--kw-rule-strong);
  }
  .work-card:is(:hover, :focus-within) .work-card__title a {
    color: var(--kw-fg-link);
  }

  .work-card__body {
    display: grid;
    gap: var(--kw-space-4);
    padding: var(--kw-space-6);
  }

  .work-card__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--kw-space-3);
  }
  .work-card__date {
    font-size: var(--kw-fs-mono-sm);
    color: var(--kw-fg-muted);
  }

  .work-card__title {
    margin: 0;
    font-family: var(--kw-font-display);
    font-size: clamp(var(--kw-fs-h3), 3vw, var(--kw-fs-h2));
    font-weight: var(--kw-fw-medium);
    line-height: var(--kw-lh-snug);
    letter-spacing: var(--kw-ls-display);
  }
  .work-card__title a {
    color: var(--kw-fg-display);
    text-decoration: none;
    border-bottom: 0;
    transition: color var(--kw-duration-fast) var(--kw-easing);
  }

  .work-card__description {
    margin: 0;
    color: var(--kw-fg-muted);
    font-size: var(--kw-fs-body-sm);
    line-height: var(--kw-lh-normal);
  }

  .work-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--kw-space-2);
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .work-card__tag {
    font-size: var(--kw-fs-mono-xs);
  }

  .work-card__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--kw-space-4);
    margin-top: var(--kw-space-2);
  }
  .work-card__btn {
    padding: 10px 20px;
  }
  .work-card__external {
    font-family: var(--kw-font-mono);
    font-size: var(--kw-fs-mono-sm);
    color: var(--kw-fg-link);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color var(--kw-duration-fast) var(--kw-easing);
  }
  .work-card__external:hover {
    border-bottom-color: var(--kw-fg-link);
  }

  .work-card--featured .work-card__body {
    padding: var(--kw-space-8);
  }
  .work-card--featured .work-card__title {
    font-size: var(--kw-fs-h1);
  }
</style>
