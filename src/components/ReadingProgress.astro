<div class="reading-progress" aria-hidden="true">
  <svg class="reading-progress__svg" viewBox="0 0 100 12" preserveAspectRatio="none" focusable="false">
    <path class="reading-progress__road" d="M0 7 C18 2 34 10 50 6 S82 3 100 7" pathLength="100" />
    <path class="reading-progress__fill" d="M0 7 C18 2 34 10 50 6 S82 3 100 7" pathLength="100" />
    <g class="reading-progress__stations">
      <circle cx="0" cy="7" r="1.2" />
      <circle cx="25" cy="5.7" r="1" />
      <circle cx="50" cy="6" r="1" />
      <circle cx="75" cy="5.2" r="1" />
      <circle cx="100" cy="7" r="1.2" />
    </g>
  </svg>
</div>

<script>
  // Scroll-Driven Animations (issue #499)。名前付き view-timeline 対応ブラウザは
  // CSS (下記 <style> の @supports ブロック) だけで stroke-dashoffset を駆動し、
  // このスクリプトは早期 return してメインスレッドの scroll ハンドラを増やさない。
  // CSS 側と同じ機能 (animation-timeline) を検出する。
  const supportsScrollTimeline = () => {
    try {
      return typeof CSS !== 'undefined' && CSS.supports && CSS.supports('animation-timeline: --x');
    } catch {
      return false;
    }
  };

  const initReadingProgress = () => {
    const root = document.querySelector<HTMLElement>('.reading-progress');
    const fill = document.querySelector<SVGPathElement>('.reading-progress__fill');
    const article = document.querySelector<HTMLElement>('.post');
    if (!root || !fill || !article) return;

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches ||
      document.documentElement.classList.contains('reduce-motion');
    if (reduceMotion) {
      root.dataset.reducedMotion = 'true';
      fill.style.strokeDashoffset = '0';
      return;
    }

    root.dataset.reducedMotion = 'false';

    // CSS 側 (animation-timeline: scroll()) が駆動できるブラウザでは JS のスクロール
    // ハンドラを一切登録しない。fill の初期値は CSS の @supports ブロックに委ねる。
    if (supportsScrollTimeline()) {
      root.dataset.cssTimeline = 'true';
      return;
    }

    let ticking = false;

    const update = () => {
      ticking = false;
      const rect = article.getBoundingClientRect();
      const scrollable = Math.max(1, rect.height - window.innerHeight);
      const progress = Math.min(1, Math.max(0, -rect.top / scrollable));
      fill.style.strokeDashoffset = String(100 - progress * 100);
    };

    const requestUpdate = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(update);
    };

    update();
    window.addEventListener('scroll', requestUpdate, { passive: true });
    window.addEventListener('resize', requestUpdate);
    document.addEventListener('astro:before-swap', () => {
      window.removeEventListener('scroll', requestUpdate);
      window.removeEventListener('resize', requestUpdate);
    }, { once: true });
  };

  initReadingProgress();
  document.addEventListener('astro:page-load', initReadingProgress);
</script>

<style>
  .reading-progress {
    position: sticky;
    top: 0;
    z-index: 45;
    width: 100%;
    height: 18px;
    margin: calc(-1 * var(--kw-space-6)) 0 var(--kw-space-6);
    pointer-events: none;
  }

  .reading-progress__svg {
    display: block;
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  .reading-progress__road,
  .reading-progress__fill {
    fill: none;
    stroke-linecap: round;
    stroke-width: 1.4;
    vector-effect: non-scaling-stroke;
  }

  .reading-progress__road {
    stroke: var(--kw-road, var(--kw-rule));
    opacity: 0.28;
  }

  .reading-progress__fill {
    stroke: var(--kw-accent);
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
  }

  /* -------------------------------------------------------------
   * Scroll-Driven Animations (issue #499)
   *
   * 対応ブラウザでは BlogPost.astro の main.post-layout が定義する
   * view-timeline-name: --kw-post-scroll を参照し、本文領域のスクロール進捗を
   * メインスレッドなしで stroke-dashoffset に直接接続する。
   * 非対応ブラウザ (Firefox 等) は上部 <script> の rAF フォールバックが担う。
   *
   * reduce-motion 時は即時表示 (現行仕様維持) のため、timeline アニメを適用しない。
   * timeline 駆動アニメは wall-clock duration に依存しないため global.css の
   * 一律 duration 0.01ms 上書きでは止まらない。OS 設定 (@media) と手動設定
   * (html.reduce-motion / data-reduced-motion) の双方を明示的に除外する。
   * ------------------------------------------------------------- */
  @supports (animation-timeline: --x) {
    @media (prefers-reduced-motion: no-preference) {
      :global(html:not(.reduce-motion)) .reading-progress:not([data-reduced-motion='true']) .reading-progress__fill {
        animation: kw-reading-progress-fill linear both;
        animation-timeline: --kw-post-scroll;
        animation-range: cover 0% cover 100%;
      }
    }
  }
  @keyframes kw-reading-progress-fill {
    from { stroke-dashoffset: 100; }
    to   { stroke-dashoffset: 0; }
  }

  .reading-progress__stations circle {
    fill: var(--kw-bg);
    stroke: var(--kw-road, var(--kw-rule-strong));
    stroke-width: 0.7;
    vector-effect: non-scaling-stroke;
  }

  .reading-progress[data-reduced-motion='true'] .reading-progress__fill {
    opacity: 0.45;
  }

  @media (prefers-reduced-motion: reduce) {
    .reading-progress__fill {
      transition: none;
    }
  }
</style>
