---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const items = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{
  items.length > 0 && (
    <details class="toc" open>
      <summary class="toc__summary">目次</summary>
      <nav aria-label="記事の目次">
        <ol class="toc__list">
          {items.map((h) => (
            <li class:list={['toc__item', h.depth === 3 && 'toc__item--sub']}>
              <a class="toc__link" href={`#${h.slug}`}>
                {h.text}
              </a>
            </li>
          ))}
        </ol>
      </nav>
    </details>
  )
}

<style>
  .toc {
    background: var(--kw-bg-card);
    border: 1px solid var(--kw-rule);
    border-radius: var(--kw-radius-md);
    padding: var(--kw-space-5) var(--kw-space-6);
  }
  .toc__summary {
    font-family: var(--kw-font-display);
    font-weight: var(--kw-fw-medium);
    font-size: var(--kw-fs-body-sm);
    color: var(--kw-fg-display);
    cursor: pointer;
    padding-block: 0.15rem;
    user-select: none;
    letter-spacing: var(--kw-ls-display);
  }
  .toc__list {
    list-style: none;
    padding: 0;
    margin: var(--kw-space-3) 0 0;
    display: grid;
    gap: var(--kw-space-2);
  }
  .toc__item {
    line-height: var(--kw-lh-snug);
  }
  .toc__item--sub {
    padding-inline-start: var(--kw-space-4);
  }
  .toc__link {
    font-family: var(--kw-font-mono);
    font-size: var(--kw-fs-mono-sm);
    color: var(--kw-fg-muted);
    text-decoration: none;
    display: block;
    padding-block: 2px;
    transition: color var(--kw-duration-fast) var(--kw-easing);
    border-bottom: 0;
  }
  .toc__link:hover {
    color: var(--kw-fg-link);
    border-bottom: 0;
  }

  @media (min-width: 901px) {
    .toc summary::-webkit-details-marker { display: none; }
    .toc summary::marker { display: none; }
    .toc__summary {
      cursor: default;
      pointer-events: none;
    }
  }
</style>
