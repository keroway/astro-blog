---
import MotifPanel from './MotifPanel.astro';

interface Props {
  index: number;
  key: string;
  title: string;
  description: string;
  visualKey?: string;
}
const { index, key, title, description, visualKey = key } = Astro.props;
const num = (index + 1).toString().padStart(2, '0');
---

<article class="focus-card kw-lift" data-reveal>
  <MotifPanel visualKey={visualKey} label={key} />
  <div class="focus-card__eyebrow kw-eyebrow">
    <span class="focus-card__num kw-tabular">{num}<span class="focus-card__slash">/</span></span>
    <span>{key}</span>
  </div>
  <h3 class="focus-card__title">{title}</h3>
  <p class="focus-card__desc">{description}</p>
</article>

<style>
  .focus-card {
    container-type: inline-size;
    display: grid;
    gap: var(--kw-space-3);
    padding: var(--kw-space-6);
    background: var(--kw-bg-card);
    border-radius: var(--kw-radius-lg);
  }

  .focus-card__eyebrow {
    display: flex;
    gap: 10px;
    align-items: baseline;
    margin-bottom: var(--kw-space-1);
    white-space: nowrap;
  }
  .focus-card__num {
    color: var(--kw-accent);
    white-space: nowrap;
  }
  .focus-card__slash {
    margin-left: var(--kw-space-1);
  }
  .focus-card__title {
    font-family: var(--kw-font-display);
    font-size: var(--kw-fs-h3);
    font-weight: var(--kw-fw-medium);
    color: var(--kw-fg-display);
    letter-spacing: var(--kw-ls-display);
    margin: 0 0 var(--kw-space-2);
    line-height: var(--kw-lh-snug);
  }
  .focus-card__desc {
    font-family: var(--kw-font-body);
    font-size: var(--kw-fs-body-sm);
    line-height: var(--kw-lh-relaxed);
    color: var(--kw-fg-muted);
    text-indent: 1em;
    margin: 0;
  }

  @container (width < 360px) {
    .focus-card__eyebrow {
      white-space: normal;
    }
    .focus-card__title {
      font-size: clamp(var(--kw-fs-h4), 8cqi, var(--kw-fs-h3));
    }
  }
</style>
