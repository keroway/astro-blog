---
import { ClientRouter } from "astro:transitions";
import { Font } from "astro:assets";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import "../styles/global.css";

interface Props {
	title: string;
	description: string;
	image?: string | null;
	locale?: string;
	canonicalUrl?: string;
	articleSchema?: Record<string, unknown>;
}

const { title, description, image = "/og-default.png", locale = "ja_JP", canonicalUrl, articleSchema } = Astro.props;
const canonicalURL = canonicalUrl ? new URL(canonicalUrl) : new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = image ? new URL(image, Astro.url).toString() : null;
const ogImageAlt = title || SITE_TITLE;

const siteUrl = Astro.site ? new URL("/", Astro.site).toString() : `${Astro.url.origin}/`;
const websiteSchema = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	name: SITE_TITLE,
	description: SITE_DESCRIPTION,
	url: siteUrl,
	inLanguage: locale.replace("_", "-"),
};
---

<!-- Theme & reduced-motion: FOUC prevention — must run before first paint -->
<script is:inline>
  (function () {
    try {
      var s = localStorage.getItem('theme');
      var t = s === 'dark' || s === 'light' ? s
        : window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      document.documentElement.dataset.theme = t;
    } catch (e) {}
    // モーション低減の判定 (手動設定 OR OS 設定)。
    // キー 'reduce-motion' は src/scripts/reduce-motion.ts と一致させること。
    var reduced = false;
    try { reduced = localStorage.getItem('reduce-motion') === 'true'; } catch (e) {}
    if (reduced) document.documentElement.classList.add('reduce-motion');
    try {
      if (!reduced && window.matchMedia) {
        reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      }
    } catch (e) {}
    // スクロール演出 (issue #377) の初期非表示は kw-anim でゲートする。
    // モーション許可時のみ初回描画前に付与し、チラつきを避ける。
    if (!reduced) document.documentElement.classList.add('kw-anim');
    // 文字サイズ (issue #378)。キー 'font-size' は src/scripts/font-size.ts と一致させること。
    try {
      if (localStorage.getItem('font-size') === 'large') {
        document.documentElement.classList.add('fs-large');
      }
    } catch (e) {}
  })();
</script>

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="generator" content={Astro.generator} />

<!-- Web fonts — self-hosted via Astro Fonts API + Fontsource (ADR 0013) -->
<Font cssVariable="--font-display" preload />
<Font cssVariable="--font-body" preload />
<Font cssVariable="--font-mono" />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />
<ClientRouter fallback="animate" />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:locale" content={locale} />
{ogImageUrl && (
	<>
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content={ogImageAlt} />
	</>
)}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
{ogImageUrl && (
	<>
		<meta property="twitter:image" content={ogImageUrl} />
		<meta property="twitter:image:alt" content={ogImageAlt} />
	</>
)}

<!-- Structured data (JSON-LD) -->
<script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
{articleSchema && (
	<script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
)}

<!-- Vercel Web Analytics — cookie-less, injected via Vercel's edge path -->
<script is:inline defer src="/_vercel/insights/script.js"></script>
