---
const links = [
  { id: 'home',  label: 'home',  href: '/'      },
  { id: 'works', label: 'works', href: '/works'  },
  { id: 'blog',  label: 'blog',  href: '/blog'   },
  { id: 'about', label: 'about', href: '/about'  },
];

const pathname = Astro.url.pathname;
const normalizePath = (v: string) => (v === '/' ? '/' : v.replace(/\/$/, ''));
const currentPath = normalizePath(pathname);
const isActive = (href: string) => {
  const target = normalizePath(href);
  return currentPath === target || (target !== '/' && currentPath.startsWith(`${target}/`));
};
---

<header class="kw-header" role="banner">
  <a href="/" class="kw-header__brand" aria-label="鴎路 (keroway.com)">
    <span class="kw-header__brand-jp">鴎路</span>
    <span class="kw-header__brand-en">keroway.com</span>
  </a>

  <nav class="kw-header__nav" aria-label="primary">
    {links.map((l, i) => (
      <a
        href={l.href}
        class="kw-header__link"
        aria-current={isActive(l.href) ? 'page' : undefined}
      >
        <span class="kw-header__link-num">{(i + 1).toString().padStart(2, '0')}</span>
        <span class="kw-header__link-label">{l.label}</span>
      </a>
    ))}
  </nav>

  <div class="kw-header__date" aria-label="issue date">令和八年 · 2026</div>
</header>

<style>
  .kw-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--kw-space-8);
    padding: var(--kw-space-6) var(--kw-space-10);
    border-bottom: 1px solid var(--kw-rule);
    background: var(--kw-bg);
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .kw-header__brand {
    display: flex;
    align-items: baseline;
    gap: var(--kw-space-3);
    text-decoration: none;
    border-bottom: 0 !important;
  }
  .kw-header__brand-jp {
    font-family: var(--kw-font-display);
    font-size: 22px;
    font-weight: var(--kw-fw-medium);
    color: var(--kw-fg-display);
    letter-spacing: -0.01em;
    line-height: 1;
  }
  .kw-header__brand-en {
    font-family: var(--kw-font-mono);
    font-size: var(--kw-fs-mono-sm);
    color: var(--kw-fg-muted);
  }

  .kw-header__nav {
    display: flex;
    align-items: baseline;
    gap: var(--kw-space-6);
  }

  .kw-header__link {
    display: flex;
    align-items: baseline;
    gap: var(--kw-space-2);
    font-family: var(--kw-font-mono);
    font-size: var(--kw-fs-mono-sm);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--kw-fg-muted);
    text-decoration: none;
    padding: 4px 0;
    border-bottom: 1px solid transparent;
    transition: color var(--kw-duration-fast) var(--kw-easing),
                border-color var(--kw-duration-fast) var(--kw-easing);
  }
  .kw-header__link:hover {
    color: var(--kw-fg-display);
    border-bottom-color: var(--kw-rule-strong);
  }
  .kw-header__link[aria-current="page"] {
    color: var(--kw-fg-display);
  }

  .kw-header__link-num {
    font-size: 10px;
    color: var(--kw-accent);
    font-variant-numeric: tabular-nums;
  }

  .kw-header__date {
    font-family: var(--kw-font-mono);
    font-size: var(--kw-fs-mono-xs);
    text-transform: uppercase;
    letter-spacing: var(--kw-ls-eyebrow);
    color: var(--kw-fg-muted);
    white-space: nowrap;
  }

  @media (max-width: 640px) {
    .kw-header {
      padding: var(--kw-space-4) var(--kw-space-5);
      gap: var(--kw-space-4);
    }
    .kw-header__date {
      display: none;
    }
    .kw-header__brand-en {
      display: none;
    }
    .kw-header__nav {
      gap: var(--kw-space-4);
    }
  }
</style>
