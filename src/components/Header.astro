---
const links = [
  { id: 'home',  label: 'home',  href: '/'      },
  { id: 'works', label: 'works', href: '/works'  },
  { id: 'blog',  label: 'blog',  href: '/blog'   },
  { id: 'about', label: 'about', href: '/about'  },
];

const pathname = Astro.url.pathname;
const normalizePath = (v: string) => (v === '/' ? '/' : v.replace(/\/$/, ''));
const currentPath = normalizePath(pathname);
const isActive = (href: string) => {
  const target = normalizePath(href);
  return currentPath === target || (target !== '/' && currentPath.startsWith(`${target}/`));
};
---

<header class="kw-header" role="banner">
  <a href="/" class="kw-header__brand" aria-label="keroway.com">
    <span class="kw-header__brand-mark" aria-hidden="true">✦</span>
    <span class="kw-header__brand-en">keroway.com</span>
  </a>

  <nav class="kw-header__nav" aria-label="primary">
    {links.map((l, i) => (
      <a
        href={l.href}
        class="kw-header__link"
        aria-current={isActive(l.href) ? 'page' : undefined}
      >
        <span class="kw-header__link-num">{(i + 1).toString().padStart(2, '0')}</span>
        <span class="kw-header__link-label">{l.label}</span>
      </a>
    ))}
  </nav>

  <div class="kw-header__actions">
    <button id="theme-toggle" class="kw-header__theme-btn" type="button" aria-label="ダークモードに切り替える">
      <span aria-hidden="true">☽</span>
    </button>
  </div>
</header>

<script>
  function initThemeToggle() {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;
    const el = btn;
    const icon = el.querySelector('span')!;

    function sync() {
      const dark = document.documentElement.dataset.theme === 'dark';
      icon.textContent = dark ? '☀' : '☽';
      el.setAttribute('aria-label', dark ? 'ライトモードに切り替える' : 'ダークモードに切り替える');
    }

    sync();

    el.addEventListener('click', () => {
      const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
      document.documentElement.dataset.theme = next;
      try { localStorage.setItem('theme', next); } catch (e) {}
      sync();
    });
  }

  initThemeToggle();

  document.addEventListener('astro:after-swap', () => {
    try {
      const stored = localStorage.getItem('theme');
      if (stored === 'dark' || stored === 'light') {
        document.documentElement.dataset.theme = stored;
      }
    } catch (e) {}
    initThemeToggle();
  });
</script>

<style>
  .kw-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--kw-space-8);
    padding: var(--kw-space-6) var(--kw-space-10);
    border-bottom: 1px solid var(--kw-rule);
    background: var(--kw-bg);
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .kw-header__brand {
    display: flex;
    align-items: baseline;
    gap: var(--kw-space-3);
    text-decoration: none;
    border-bottom: 0 !important;
  }
  .kw-header__brand-mark {
    font-size: 18px;
    color: var(--kw-accent);
    line-height: 1;
    display: inline-block;
    transform: translateY(1px);
  }
  .kw-header__brand-en {
    font-family: var(--kw-font-mono);
    font-size: var(--kw-fs-mono-sm);
    color: var(--kw-fg-display);
    font-weight: var(--kw-fw-medium);
    letter-spacing: 0;
  }

  .kw-header__nav {
    display: flex;
    align-items: baseline;
    gap: var(--kw-space-6);
  }

  .kw-header__link {
    display: flex;
    align-items: baseline;
    gap: var(--kw-space-2);
    font-family: var(--kw-font-mono);
    font-size: var(--kw-fs-mono-sm);
    text-transform: uppercase;
    letter-spacing: 0;
    color: var(--kw-fg-muted);
    text-decoration: none;
    padding: var(--kw-space-1) 0;
    border-bottom: 1px solid transparent;
    transition: color var(--kw-duration-fast) var(--kw-easing),
                border-color var(--kw-duration-fast) var(--kw-easing);
  }
  .kw-header__link:hover {
    color: var(--kw-fg-display);
    border-bottom-color: var(--kw-rule-strong);
  }
  .kw-header__link[aria-current="page"] {
    color: var(--kw-fg-display);
  }

  .kw-header__link-num {
    font-size: var(--kw-fs-mono-xs);
    color: var(--kw-accent);
    font-variant-numeric: tabular-nums;
  }

  .kw-header__actions {
    display: flex;
    align-items: center;
    gap: var(--kw-space-4);
  }

  .kw-header__theme-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--kw-fg-muted);
    font-size: var(--kw-fs-body-sm);
    line-height: 1;
    padding: var(--kw-space-1) var(--kw-space-2);
    border-radius: var(--kw-radius-sm);
    transition: color var(--kw-duration-fast) var(--kw-easing);
  }
  .kw-header__theme-btn:hover {
    color: var(--kw-fg-display);
  }
  .kw-header__theme-btn:focus-visible {
    outline: 2px solid var(--kw-accent);
    outline-offset: 2px;
  }

  @media (max-width: 640px) {
    .kw-header {
      padding: var(--kw-space-4) var(--kw-space-5);
      gap: var(--kw-space-4);
    }
    .kw-header__brand-en {
      display: none;
    }
    .kw-header__nav {
      gap: var(--kw-space-4);
    }
  }
</style>
