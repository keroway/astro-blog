# Keystatic 環境変数サンプル
# 本ファイルは git 管理下、シークレットを直書きしないこと。
# 実値は .env (gitignore 済み) または Vercel 環境変数に設定する。
# セットアップ手順: docs/cms-flow.md

# ---- Keystatic storage mode ----
# 本番 (Vercel) では "github" を設定して GitHub mode (branch storage) を有効化する。
# 未設定 / "local" のときは ./src/content/* に直接書き込むローカルモードで動く。
# Vercel Production (VERCEL_ENV=production) では "github" 必須。
# 未設定だと keystatic.config.ts がビルド時に fail-fast する。Preview / Dev は local OK。
KEYSTATIC_STORAGE_KIND=local

# storage=github のときに使うリポジトリ。
# keystatic.config.ts のデフォルトは keroway/astro-blog。
KEYSTATIC_GITHUB_REPO_OWNER=keroway
KEYSTATIC_GITHUB_REPO_NAME=astro-blog

# ---- Keystatic GitHub App ----
# https://keystatic.com/docs/github-mode の手順で生成される値。
# CLIENT_SECRET と KEYSTATIC_SECRET はシークレット扱い。
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=

# Astro はビルド時に "PUBLIC_" 接頭辞の env のみクライアントに露出する。
# Keystatic Admin UI が GitHub App をインストールするボタンの遷移先に使うため公開して問題ない。
PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=
