# build output
dist/
# Vercel adapter (@astrojs/vercel) build artifact
.vercel/
# generated types
.astro/

# dependencies
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# environment variables
.env
.env.production

# macOS-specific files
.DS_Store
# Windows NTFS Alternate Data Streams (accidentally committed via cross-platform tools)
*:Zone.Identifier

# local tooling / test artifacts。
# settings.json / agents / commands / rules / hooks はチーム共有する Claude Code 設定としてトラッキング。
# settings.local.json / worktrees / file-history などのセッションローカルなものは ignore のまま。
.claude/*
!.claude/settings.json
!.claude/agents/
!.claude/commands/
!.claude/rules/
!.claude/hooks/
.serena/
test-results/
.playwright-mcp/
.pnpm-store/
# Lighthouse CI artifacts
lhci-reports/
.lighthouseci/
# lychee link checker on-disk cache (regenerated each run)
.lycheecache
# pi coding agent (remote-pi) のセッションデータ
.pi/
